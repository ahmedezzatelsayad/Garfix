# ─────────────────────────────────────────────────────────────────────────────
# GarfiX EOS v12.0 — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# UNIFIED POSTGRESQL CONFIGURATION (All Environments)
#
# Development: Use Docker Compose (docker compose up -d postgres valkey)
#   DATABASE_URL="postgresql://garfix:garfix_strong_pass_change_me@localhost:5432/garfix?schema=public"
#   DATABASE_DIRECT_URL="postgresql://garfix:garfix_strong_pass_change_me@localhost:5432/garfix"
#
# CI/CD: GitHub Actions provides postgres service automatically
#
# Production: Neon, RDS, Supabase, or managed PostgreSQL
# ─────────────────────────────────────────────────────────────────────────────

# Database (PostgreSQL — required in all environments)
DATABASE_URL="postgresql://garfix:garfix_strong_pass_change_me@localhost:5432/garfix?schema=public&connection_limit=20&pool_timeout=30"
DATABASE_DIRECT_URL="postgresql://garfix:garfix_strong_pass_change_me@localhost:5432/garfix"

# Database Pool Size (PostgreSQL only, ignored by SQLite)
DATABASE_POOL_SIZE=20

# JWT Authentication (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=garfix-build-secret-key-32-chars-long!!
JWT_REFRESH_SECRET=garfix-refresh-secret-32-chars!!

# Payments Encryption Key
PAYMENTS_ENC_KEY=garfix-payments-encryption-32-char-key!!

# Founder Account Email
FOUNDER_EMAIL=founder@garfix.com

# Valkey/Redis Connection (for BullMQ queues)
VALKEY_URL=valkey://localhost:6379

# SMTP Configuration (optional — email features disabled if missing)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@garfix.com

# WhatsApp Configuration (optional)
# WHATSAPP_ALLOWED_SENDERS=+1234567890,+0987654321

# Node Environment
NODE_ENV=development

# Next.js Configuration
NEXT_TELEMETRY_DISABLED=1

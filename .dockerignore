# ─────────────────────────────────────────────────────────────────────────────
# GarFiX — Docker Ignore
# Minimize Docker context size for faster builds
# ─────────────────────────────────────────────────────────────────────────────

# Version Control
.git
.gitignore
.gitattributes

# CI/CD & GitHub
.github

# IDE & Editor
.vscode
.idea
*.swp
*.swo
*.sublime-*

# OS Files
.DS_Store
Thumbs.db
desktop.ini

# Documentation
docs
*.md
!README.md

# Tests
src/lib/__tests__
src/lib/founder-validation/__tests__
e2e
playwright.config.ts
**/*.test.ts
**/*.spec.ts
**/__tests__/**

# Scripts (not needed in Docker — but keep verify script available)
scripts/*.ts
scripts/*.log

# AI agent context
agent-ctx

# Logs
*.log
dev.log
server.log
npm-debug.log*

# Next.js build cache (rebuilt in Docker)
.next
node_modules

# Docker files (prevent recursive builds)
docker-compose*.yml
Dockerfile
.dockerignore

# Config files not needed in production
Caddyfile
Caddyfile.dev
.env
.env.*
!.env.example

# Tool artifacts
coverage
.nyc_output
tsconfig.prod.json
tool-results
download
skills
worklog.md

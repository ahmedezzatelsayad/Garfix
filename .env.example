# ─────────────────────────────────────────────────────────────────────────────
# GarfiX EOS v12.0 — Environment Configuration TEMPLATE
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` (which is git-ignored) and fill in real values.
#
# IMPORTANT — Secret Hygiene (SEC-C3 hardening):
#   * `.env` is git-ignored via the `.env*` rule in `.gitignore`.
#   * Never commit real secrets. Use `.env.example` for placeholders only.
#   * In production, set these via your hosting provider's secret manager
#     (Vercel/Render/RDS Secrets Manager, Kubernetes secrets, dotenv-vault,
#     Doppler, etc.) — never via committed files.
#   * The startup check refuses to boot in production if any secret matches
#     a known placeholder value.
# ─────────────────────────────────────────────────────────────────────────────

# Database (PostgreSQL — required in all environments)
DATABASE_URL="postgresql://USER:STRONG_PASSWORD@HOST:5432/DBNAME?schema=public&connection_limit=20&pool_timeout=30"
DATABASE_DIRECT_URL="postgresql://USER:STRONG_PASSWORD@HOST:5432/DBNAME"
DATABASE_POOL_SIZE=20

# JWT Authentication — generate with: openssl rand -hex 64
# Cycle 2 hardening: secrets must be high-entropy (>= 32 chars, no placeholder
# patterns). The startup check rejects secrets matching /garfix/i, /change[-_]?me/i,
# /password/i, etc. JWT_SECRET and JWT_REFRESH_SECRET MUST differ.
JWT_SECRET=REPLACE_WITH_RANDOM_64_BYTE_HEX_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_RANDOM_64_BYTE_HEX_STRING
JWT_ACCESS_TTL_SECONDS=1800
JWT_REFRESH_TTL_SECONDS=2592000
# HIGH-005 FIX (Cycle 2): OWASP 2025 recommends bcrypt cost >= 12.
# Existing hashes at lower cost are auto-upgraded on next login.
BCRYPT_ROUNDS=12
BCRYPT_MIN_ROUNDS=12

# Payments Encryption Key — generate with: openssl rand -base64 32
PAYMENTS_ENC_KEY=REPLACE_WITH_RANDOM_32_BYTE_BASE64_STRING

# Founder Account Email
FOUNDER_EMAIL=founder@example.com

# Valkey/Redis Connection (for BullMQ queues + rate limiting + token blacklist)
# Required in any multi-instance production deployment.
VALKEY_URL=valkey://localhost:6379

# Trusted proxy IPs (comma-separated) — set to your load balancer / CDN egress
# so that rate-limit-by-IP and audit logs see the real client IP.
# TRUSTED_PROXIES=10.0.0.1,10.0.0.2

# SMTP Configuration (optional — email features disabled if missing)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@garfix.com

# WhatsApp Configuration (optional)
# WHATSAPP_ALLOWED_SENDERS=+1234567890,+0987654321

# Node Environment
NODE_ENV=development

# Next.js Configuration
NEXT_TELEMETRY_DISABLED=1

# Session concurrency limit (optional, default 5)
MAX_SESSIONS_PER_USER=5

# Cookie sameSite policy (lax | strict | none). Use 'none' only if you
# serve the API from a different origin than the SPA (requires HTTPS).
COOKIE_SAMESITE=lax

# ─── Cycle 3 hardening ────────────────────────────────────────────────────
# SEC-H4: SessionRegistry enforcement. Set to "true" AFTER deploying this
# code and waiting 30 min (one access-token TTL). See auth.ts comment for
# the full rollout plan. Default: false (preserves backward compat).
SESSION_REGISTRY_ENFORCED=false

# LOW-003: Cookie `secure` flag override. By default, secure=true in
# production only. Set COOKIE_SECURE=true to force on (e.g. dev HTTPS), or
# COOKIE_SECURE=false to force off (e.g. staging over HTTP). Leave unset
# for the default production-only behavior.
# COOKIE_SECURE=true

# LOW-005: Maximum JSON request body size in bytes (default: 1048576 = 1 MiB).
# Oversize requests are rejected before buffering to prevent memory DoS.
# Routes that need larger payloads (file uploads) bypass parseJsonBody.
MAX_JSON_BODY_BYTES=1048576

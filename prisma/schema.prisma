// ────────────────────────────────────────────────────────────────────────────
// Invoice Brain — learning templates for the hybrid (pattern + AI) extractor.
// (P1-invoice-brain / checklist 2.1, 2.2)
// ────────────────────────────────────────────────────────────────────────────

// A learned extraction template for a document SHAPE (fingerprint).
// Named "InvoiceBrainTemplate" to avoid collision with the print-layout
// `InvoiceTemplate` model above. `fields` is a JSON string of
// FieldTemplate[] (SQLite-compatible; works as Json on PostgreSQL too).
model InvoiceBrainTemplate {
  fingerprint String   @id // 16-char sha256 prefix of the structural/content fingerprint
  fields      String   // JSON: [{field, label, regex}, ...]
  sampleCount Int      @default(1) // times this template was successfully reused
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime @updatedAt

  @@map("invoice_brain_templates")
}

// A learned header→field mapping for a tabular source's column set.
// Resolved once per distinct column-set (synonyms first, AI fallback once),
// then reused for every row of every file with the same headers.
model InvoiceBrainHeaderMap {
  headerFingerprint String   @id // 16-char sha256 prefix of sorted lowercased headers
  mapping           String   // JSON: { "column name": "field", ... }
  sampleCount       Int      @default(1)
  createdAt         DateTime @default(now())
  lastUsedAt        DateTime @updatedAt

  @@map("invoice_brain_header_maps")
}


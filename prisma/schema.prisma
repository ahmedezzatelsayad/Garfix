// NOTE: Financial fields use Decimal instead of Float for production accuracy.
// SQLite doesn't support Decimal, so in dev it falls back to Float-like behavior.
// For PostgreSQL production, Decimal ensures exact precision (no floating-point errors).
// This prevents issues like 0.1 + 0.2 = 0.30000000000000004

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  nameAr    String?
  nameEn    String?
  password  String?
  role      String   @default("user")
  companyId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company? @relation(fields: [companyId], references: [id])
}

model Company {
  id                String   @id @default(cuid())
  name              String
  nameAr            String?  // Arabic company name
  code              String   @unique @default(cuid())
  slug              String   @unique @default("default-slug")
  plan              String   @default("trial")
  subscriptionStatus String  @default("inactive")
  currency          String   @default("USD")
  currencyDecimalPlaces Int  @default(3)
  taxId             String?
  vatNumber         String?  // VAT registration number
  address           String?
  phone             String?  // Company phone
  email             String?  // Company email
  country           String?  // Country code (e.g., KW)
  defaultTaxRate    String   @default("0")
  emoji             String?  // UI branding emoji
  color             String?  // UI branding color
  trialEndsAt       DateTime? // Trial period end date
  deletedAt         DateTime?  // Soft delete support
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  users             User[]
  accounts          Account[]
  clients           Client[]
  suppliers         Supplier[]
  vouchers          Voucher[]
  paymentVouchers   PaymentVoucher[]
  openingBalances   OpeningBalance[]
  profitDistributions ProfitDistribution[]
  lettersOfCredit   LetterOfCredit[]
  productCatalogs   ProductCatalog[]
  inventoryItems    InventoryItem[]
  financialPeriods  FinancialPeriod[]
  companyRuntime    CompanyRuntime?
  employees         Employee[]
}

// ─── Chart of Accounts ───

model Account {
  id          Int      @id @default(autoincrement())
  code        String
  name        String
  nameAr      String?  // Arabic name
  nameEn      String?  // English name (alias for name)
  type        String   // asset, liability, equity, revenue, expense
  balance     Decimal  @default(0)
  currency    String   @default("USD")
  companySlug String   @default("default")
  parentId    String?
  companyId   String
  isActive    Boolean  @default(true)
  version     Int      @default(0) // P0-8: Optimistic locking / row versioning for balance updates
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company? @relation(fields: [companyId], references: [id])
  parent      Account? @relation("AccountHierarchy", fields: [parentId], references: [id])
  children    Account[] @relation("AccountHierarchy")
  openingBalances      OpeningBalance[]
  voucherLines         VoucherLine[]
  bankAccounts         BankAccount[]
  fixedAssetsGl        FixedAsset[] @relation("FixedAssetGL")
  fixedAssetsDep       FixedAsset[] @relation("FixedAssetDep")
  fixedAssetsExp       FixedAsset[] @relation("FixedAssetExp")
  journalEntryLines    JournalEntryLine[] @relation("JELAccount")
  openingBalanceEntries OpeningBalanceEntry[]
  budgetItems          Budget[]
  @@unique([code, companySlug])
}

// ─── Clients (Accounts Receivable) ───

model Client {
  id            String   @id @default(cuid())
  name          String
  clientCompany String?  // Client's company/organization name
  code          String   @default(cuid())
  email         String?
  phone         String?
  address       String?
  taxId         String?
  companySlug   String   @default("default")
  companyId     String?
  isActive      Boolean  @default(true)
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company?  @relation(fields: [companyId], references: [id])
  paymentVouchers PaymentVoucher[]
  quotations      Quotation[]
  invoices        Invoice[]
}

// ─── Suppliers (Accounts Payable) ───


model Supplier {
  id          Int      @id @default(autoincrement())
  name        String
  nameEn      String?
  code        String
  email       String?
  phone       String?
  address     String?
  taxId       String?
  companySlug String   @default("default")
  companyId   String?
  isActive    Boolean  @default(true)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company? @relation(fields: [companyId], references: [id])
  paymentVouchers PaymentVoucher[]
  lettersOfCredit  LetterOfCredit[]
  purchaseOrders   PurchaseOrder[]
  purchaseInvoices PurchaseInvoice[]
  @@unique([code, companySlug])
}

// ─── Product Catalog ───

model ProductCatalog {
  id            Int      @id @default(autoincrement())
  name          String
  aliases       String?  // JSON string of alternate product names
  sku           String   @default("")
  code          String?
  category      String?
  purchasePrice String   @default("0.000") // stored as string for Decimal precision
  sellingPrice  String   @default("0.000")
  unit          String   @default("piece")
  description   String?
  companySlug   String   @default("default")
  companyId     String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company? @relation(fields: [companyId], references: [id])
  inventoryItems InventoryItem[]
  aliases       ProductAlias[]
}

// ─── Inventory Items ───

model InventoryItem {
  id            Int      @id @default(autoincrement())
  productId     Int
  quantity      String   @default("0")
  reorderLevel  String   @default("0")
  warehouseId   Int?
  warehouse     String?
  batchNumber   String?
  expiryDate    DateTime?
  companySlug   String   @default("default")
  companyId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  product       ProductCatalog @relation(fields: [productId], references: [id])
  company       Company?  @relation(fields: [companyId], references: [id])
  warehouseRef  Warehouse? @relation(fields: [warehouseId], references: [id])
  @@unique([warehouseId, productId])
}

// ─── Warehouse ───

model Warehouse {
  id          Int      @id @default(autoincrement())
  name        String
  nameAr      String?
  code        String
  companySlug String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  inventoryItems InventoryItem[]
  @@unique([companySlug, code])
}

// ─── Financial Periods ───

model FinancialPeriod {
  id          Int      @id @default(autoincrement())
  name        String
  startDate   DateTime
  endDate     DateTime
  status      String   @default("open") // open, closed, locked
  companyId   String?
  companySlug String   @default("default")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company? @relation(fields: [companyId], references: [id])
  openingBalances OpeningBalance[]
  @@unique([name, companySlug])
}

// ─── Vouchers (Journal Entries) ───

model Voucher {
  id            Int      @id @default(autoincrement())
  number        String
  date          DateTime
  description   String?
  reference     String?
  status        String   @default("draft") // draft, posted, cancelled
  voucherType   String   @default("general") // general, payment, receipt, transfer
  companySlug   String   @default("default")
  companyId     String?
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company? @relation(fields: [companyId], references: [id])
  lines         VoucherLine[]
  @@unique([number, companySlug])
}

model VoucherLine {
  id           Int      @id @default(autoincrement())
  accountId    Int
  debit        String   @default("0.000")
  credit       String   @default("0.000")
  description  String?
  sortOrder    Int      @default(0)
  voucherId    Int
  account      Account  @relation(fields: [accountId], references: [id])
  voucher      Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)
}

// ─── Payment Vouchers (AR/AP) ───

model PaymentVoucher {
  id            Int      @id @default(autoincrement())
  number        String
  voucherNumber String?  // Alternative field name used in seed.ts
  date          DateTime
  amount        String   @default("0.000")
  paymentType   String   @default("receipt") // receipt, payment
  voucherType   String?  // receipt, payment (alternative field)
  direction     String   @default("inbound") // inbound, outbound
  payee         String?
  payer         String?
  status        String   @default("draft") // draft, posted, cancelled
  description   String?
  reference     String?
  clientId      Int?
  supplierId    Int?
  bankAccountId Int?
  companySlug   String   @default("default")
  companyId     String?
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  client        Client?   @relation(fields: [clientId], references: [id])
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  company       Company?  @relation(fields: [companyId], references: [id])
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id])
  installments  Installment[]
  @@unique([companySlug, voucherNumber])
}

model Installment {
  id              Int      @id @default(autoincrement())
  paymentVoucherId Int
  amount          String   @default("0.000")
  dueDate         DateTime
  status          String   @default("pending") // pending, paid, overdue, cancelled
  paidDate        DateTime?
  paymentRef      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  paymentVoucher  PaymentVoucher @relation(fields: [paymentVoucherId], references: [id], onDelete: Cascade)
}

// ─── Opening Balances ───

model OpeningBalance {
  id            Int      @id @default(autoincrement())
  accountId     Int
  periodId      Int
  debit         String   @default("0.000")
  credit        String   @default("0.000")
  companySlug   String   @default("default")
  companyId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  account       Account        @relation(fields: [accountId], references: [id])
  period        FinancialPeriod @relation(fields: [periodId], references: [id])
  company       Company?       @relation(fields: [companyId], references: [id])
  @@unique([accountId, periodId])
}

// ─── Profit Distribution ───

model ProfitDistribution {
  id               Int      @id @default(autoincrement())
  periodId         Int?
  totalProfit      String   @default("0.000")
  retained         String   @default("0.000")
  distributed      String   @default("0.000")
  distributionType String   @default("proportional") // proportional, equal, custom
  status           String   @default("draft") // draft, approved, executed
  notes            String?
  companySlug      String   @default("default")
  companyId        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  company          Company? @relation(fields: [companyId], references: [id])
  entries          ProfitDistributionEntry[]
}

model ProfitDistributionEntry {
  id             Int      @id @default(autoincrement())
  distributionId Int
  shareholder    String
  shareRatio     String   @default("0")
  amount         String   @default("0.000")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  distribution   ProfitDistribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)
}

// ─── Letters of Credit (Trade Finance) ───

model LetterOfCredit {
  id            Int      @id @default(autoincrement())
  lcNumber      String
  number        String?  // Legacy field
  type          String   @default("import") // import, export
  amount        String   @default("0.000")
  currency      String   @default("USD")
  status        String   @default("draft") // draft, issued, confirmed, utilized, expired, cancelled
  issueDate     String?
  expiryDate    String?
  beneficiary   String?
  issuingBank   String?
  description   String?
  reference     String?
  supplierId    Int?
  bankAccountId Int?
  companySlug   String   @default("default")
  companyId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  company       Company?  @relation(fields: [companyId], references: [id])
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id])
  lcDocuments   LetterOfCreditDocument[]
  @@unique([companySlug, lcNumber])
}

model LetterOfCreditDocument {
  id               Int      @id @default(autoincrement())
  letterOfCreditId Int
  documentType     String   // invoice, bill_of_lading, packing_list, insurance, certificate
  fileName         String
  fileUrl          String?
  uploadedAt       DateTime @default(now())
  letterOfCredit   LetterOfCredit @relation(fields: [letterOfCreditId], references: [id], onDelete: Cascade)
}

// Keep the existing Post model for compatibility
model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════════════════════
// AI Fabric Models (Phases 1-16)
// ═══════════════════════════════════════════════════════════════════════════════

// ─── AI Request Log (Phase 1) ───

model AIRequestLog {
  id          Int      @id @default(autoincrement())
  companySlug String
  requestType String
  resolvedBy  String   // cache, pattern, rule, memory, ai
  provider    String?
  tokensUsed  Int?
  costUsd     Float    @default(0)
  latencyMs   Int      @default(0)
  createdAt   DateTime @default(now())
}

// ─── Cache Entry (Phase 1) ───

model CacheEntry {
  key        String   @id
  companySlug String
  value      String
  expiresAt  DateTime
  hitCount   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── AI Memory Entry (Phase 1/7) ───

model AIMemoryEntry {
  id             Int      @id @default(autoincrement())
  companySlug    String
  category       String   // decision, invoice, customer, product, digital-twin, decision_trace
  content        String
  lastAccessedAt DateTime @default(now())
  createdAt      DateTime @default(now())
}

// ─── Budget Config (Phase 6) ───

model BudgetConfig {
  companySlug      String   @id
  monthlyBudgetUsd Float    @default(0)
  currentSpendUsd  Float    @default(0)
  alertThresholdPct Int     @default(80)
  hardStopEnabled  Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ─── Company Runtime (Phase 4) ───

model CompanyRuntime {
  id                   Int      @id @default(autoincrement())
  companyId            String   @unique
  workerPoolSize       Int      @default(1)
  status               String   @default("active")
  slaTier              String?
  maxAcceptableLatencyMs Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  company              Company  @relation(fields: [companyId], references: [id])
}

// ─── Notification (Phase 6) ───

model Notification {
  id          Int      @id @default(autoincrement())
  userUid     String
  companySlug String
  type        String   @default("general")
  title       String
  body        String?
  createdAt   DateTime @default(now())
}

// ─── Job Queue (Phase 4/5) ───

model JobQueue {
  id          Int      @id @default(autoincrement())
  queue       String
  type        String
  data        String   @default("{}")
  status      String   @default("pending") // pending, running, completed, failed
  attempts    Int      @default(0)
  maxAttempts Int      @default(3)
  scheduledAt DateTime @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
}

// ─── Provider Config (Phase 3) ───

model ProviderConfig {
  taskType         String   @id
  primaryProvider  String
  fallbackProvider String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ─── Rule Candidate (Phase 11) ───

model RuleCandidate {
  id               Int      @id @default(autoincrement())
  companySlug      String
  requestType      String
  patternSignature String
  sampleCount      Int      @default(1)
  consistentOutput String?
  confidence       Float    @default(1.0)
  status           String   @default("observing") // observing, promoted, rejected
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ─── Global Pattern (Phase 12) ───

model GlobalPattern {
  patternKey              String   @id
  suggestedSku            String?
  suggestedVatCategory    String?
  suggestedCategory       String?
  contributingCompaniesCount Int     @default(1)
  confidence              Float    @default(1.0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// ─── Profit Snapshot (Phase 8) ───

model ProfitSnapshot {
  id            Int      @id @default(autoincrement())
  companySlug   String
  periodStart   DateTime
  periodEnd     DateTime
  revenueUsd    Float    @default(0)
  infraCostUsd  Float    @default(0)
  aiCostUsd     Float    @default(0)
  workerCostUsd Float    @default(0)
  profitUsd     Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── AI Score Snapshot (Phase 14) ───

model AIScoreSnapshot {
  id               Int      @id @default(autoincrement())
  companySlug      String
  period           String   // "YYYY-MM-DD"
  score            Float
  cacheHitPct      Float    @default(0)
  ruleHitPct       Float    @default(0)
  aiCallPct        Float    @default(0)
  avgCostPerRequest Float   @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  @@unique([companySlug, period])
}

// ─── Compiled Rule (Phase 16a) ───

model CompiledRule {
  id                      Int      @id @default(autoincrement())
  companySlug             String
  requestType             String
  clusterKey              String
  compiledOutput          String?
  sourceCandidateCount    Int      @default(0)
  estimatedAnnualSavingsUsd Float  @default(0)
  status                  String   @default("pending_review")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}


// ─── Invoice (Sales — expanded for e-invoicing & Kuwait compliance) ───

model Invoice {
  id              Int      @id @default(autoincrement())
  companySlug     String
  invoiceNumber   String
  clientId        String?   // Reference to Client
  clientName      String?
  clientEmail     String?
  clientPhone     String?
  clientAddress   String?
  issueDate       String
  dueDate         String?
  subtotal        String   @default("0")
  taxRate         String   @default("0")
  taxAmount       String   @default("0")
  total           String   @default("0")
  shipping        String   @default("0")
  discount        String   @default("0")
  paid            String   @default("0")
  lineItems       String?  // JSON string
  createdByEmail  String?
  createdByName   String?
  version         Int      @default(0)
  status          String   @default("draft")
  source          String?
  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Feature Flag ───

model FeatureFlag {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  label       String
  description String?
  plans       String   @default("[]")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Platform Settings ───

model PlatformSettings {
  key        String   @id
  category   String   @default("general")
  valueType  String   @default("string")
  value      String   @default("")
  updatedBy  String   @default("system")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Platform Settings History ───

model PlatformSettingsHistory {
  id         Int      @id @default(autoincrement())
  settingKey String
  newValue   String   @default("")
  changedBy  String   @default("system")
  createdAt  DateTime @default(now())
}

// ─── App User ───

model AppUser {
  uid           String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  displayName   String   @default("")
  role          String   @default("employee")
  companies     String   @default("[]")
  permissions   String   @default("{}")
  emailVerified Boolean  @default(false)
  tokenVersion  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── Product Alias (matching) ───

model ProductAlias {
  id              Int      @id @default(autoincrement())
  productCatalogId Int
  companySlug     String   @default("default")
  alias           String
  source          String   @default("manual") // manual, ai, import
  confidence      Float    @default(1.0)
  isVerified      Boolean  @default(false)
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  product         ProductCatalog @relation(fields: [productCatalogId], references: [id])
  @@unique([companySlug, alias])
}

// ─── Product Match Audit ───

model ProductMatchAudit {
  id               Int      @id @default(autoincrement())
  companySlug      String   @default("default")
  invoiceId        Int?
  inputText        String
  matchedProductId Int?
  matchedAlias     String?
  tier             String   @default("auto-match") // auto-match, suggested, new-product
  action           String   @default("auto-matched")
  confidence       Float    @default(1.0)
  resolvedBy       String?
  isUndone         Boolean  @default(false)
  undoneBy         String?
  undoneAt         DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ─── Match Override (learning) ───

model MatchOverride {
  id              Int      @id @default(autoincrement())
  companySlug     String
  inputText       String
  inputNormalized String?
  fromProductId   Int?
  toProductId     Int?
  chosenAlias     String?
  auditId         Int?
  reason          String?
  overriddenBy    String
  createdAt       DateTime @default(now())
}

// ─── Stock Movement ───

model StockMovement {
  id            Int      @id @default(autoincrement())
  companySlug   String   @default("default")
  productId     Int
  quantity      String   @default("0")
  movementType  String   @default("adjustment") // sale, purchase, adjustment, return, collision-recovery
  sourceType    String?
  sourceId      String?
  reference     String?
  createdAt     DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════════════════════════
// HR & Employee Models
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Employee ───

model Employee {
  id          String   @id @default(cuid())
  companySlug String   @default("default")
  companyId   String?
  name        String
  code        String   @default(cuid())
  phone       String?
  position    String?
  department  String?
  joinDate    String?  // YYYY-MM-DD format
  baseSalary  Decimal  @default(0)
  currency    String   @default("KWD")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company? @relation(fields: [companyId], references: [id])
  attendances HRAttendance[]
  salaries    HRSalary[]
  @@unique([code, companySlug])
}

// ─── HR Attendance ───

model HRAttendance {
  id          Int      @id @default(autoincrement())
  companySlug String   @default("default")
  employeeId  String
  date        String
  status      String   @default("present") // present, absent, late, half-day
  checkIn     String?
  checkOut    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ─── HR Salary ───

model HRSalary {
  id          Int      @id @default(autoincrement())
  companySlug String   @default("default")
  employeeId  String
  month       String   // YYYY-MM
  baseSalary  Decimal  @default(0)
  allowances  Decimal  @default(0)
  deductions  Decimal  @default(0)
  bonus       Decimal  @default(0)
  netSalary   Decimal  @default(0)
  isPaid      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════════════════════
// Permission & Module Models
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Permission ───

model Permission {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  labelAr   String?
  labelEn   String?
  category  String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Module ───

model Module {
  id          Int      @id @default(autoincrement())
  name        String
  identifier  String   @unique
  version     String   @default("1.0.0")
  description String?
  isActive    Boolean  @default(true)
  settings    String   @default("{}")  // JSON string
  installedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════════════════════
// Audit & AI Usage Log Models
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Audit Log ───

model AuditLog {
  id          Int      @id @default(autoincrement())
  companySlug String   @default("default")
  action      String
  entity      String?
  entityId    String?
  userId      String?
  details     String?  // JSON string
  createdAt   DateTime @default(now())
}

// ─── AI Usage Log ───

model AIUsageLog {
  id            Int      @id @default(autoincrement())
  companySlug   String
  endpoint      String?
  provider      String?
  model         String?
  tokensIn      Int      @default(0)
  tokensOut     Int      @default(0)
  estimatedCost Float    @default(0)
  processingMs  Int      @default(0)
  success       Boolean  @default(true)
  createdAt     DateTime @default(now())
}

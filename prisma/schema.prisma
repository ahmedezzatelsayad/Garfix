// Garfix v12 — Prisma schema
// Multi-tenant SaaS ERP/Invoicing platform
//
// ─────────────────────────────────────────────────────────────────────────────
// P1-A — DATABASE PROVIDER (dev vs production) — code-ready for the switch
// ─────────────────────────────────────────────────────────────────────────────
// The active datasource below is SQLite, because THIS SANDBOX has no PostgreSQL
// service. The schema is fully PostgreSQL-compatible: money is stored as String,
// JSON as String, and no SQLite-specific types are used — so switching to
// PostgreSQL requires NO model changes, only the datasource provider + URL.
//
// ── PRODUCTION SWITCH (literal one-line edit) ────────────────────────────────
//   1. Comment out the `sqlite` datasource block (DEV / SANDBOX) below.
//   2. Uncomment the `postgresql` datasource block (PRODUCTION) below.
//   3. Set DATABASE_URL to the postgres connection string, e.g.:
//        DATABASE_URL="postgresql://garfix:STRONG_PASS@postgres:5432/garfix?schema=public"
//      (the `postgres` service is already defined in docker-compose.yml)
//   4. Run: prisma generate && prisma migrate deploy
//
// Prisma does not support a dynamic provider via env(), so the switch is a
// literal one-line edit here. This comment block is the explicit dev-vs-prod
// config reference — the file is no longer silently/statically SQLite.
// (Resolves P1-A from TODO v13.1: code-ready, pending env switch.)
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

// ── PRODUCTION (active) ─────────────────────────────────────────────────────
// EA-002 FIX: Switched from SQLite to PostgreSQL for production readiness.
// SQLite is unsuitable for multi-tenant SaaS: no concurrent writes, no
// connection pooling, no read replicas. PostgreSQL handles all of these.
// The schema was already PostgreSQL-compatible (String for money/JSON,
// no SQLite-specific types) so no model changes were needed.
// H1 FIX: directUrl enables Prisma Studio / migrate deploy to use a direct connection while the app uses pooled URL
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

// ── DEV / SANDBOX (uncomment for local dev without PostgreSQL) ──────────────
// datasource db {
//   provider = "sqlite"
//   url      = env("DATABASE_URL")
// }

// ────────────────────────────────────────────────────────────────────────────
// Users & Auth
// ────────────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  uid           String   @unique
  email         String   @unique
  passwordHash  String
  displayName   String
  role          String   @default("employee") // admin | editor | employee | viewer
  companies     String   @default("[]") // JSON array of company slugs
  permissions   String   @default("{}") // JSON map
  tokenVersion  Int      @default(0)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  chatHistory       ChatMessage[]
  emailVerifications EmailVerification[]
  orderDeliveries   OrderDelivery[]
  auditLogs         AuditLog[]

  @@index([role])
  @@map("app_users")
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String
  token     String?  @unique
  codeHash  String?
  purpose   String   @default("email_verify") // email_verify | password_reset
  attempts  Int      @default(0)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [uid], onDelete: Cascade)

  @@index([userId, purpose, createdAt])
  @@map("email_verifications")
}

// ────────────────────────────────────────────────────────────────────────────
// Companies (Tenants)
// ────────────────────────────────────────────────────────────────────────────

model Company {
  id                          Int      @id @default(autoincrement())
  name                        String
  slug                        String   @unique
  logoBase64                  String?  // EA-013 DEPRECATED: Use storage.ts instead. This column will be removed in a future migration.
  nameAr                      String?
  emoji                       String?
  color                       String?
  phone                       String?
  email                       String?
  address                     String?
  vatNumber                   String?
  commercialRegistration      String? // السجل التجاري (Kuwait CR number)
  currency                    String   @default("KWD")
  country                     String? // KW | SA | AE | BH | OM | QA
  timezone                    String?
  defaultTaxRate              String   @default("0")
  // Gulf-specific settings
  weekendDays                 String   @default("[5,6]") // JSON array: 5=Fri, 6=Sat (Gulf weekend)
  ramadanHours                Boolean  @default(false) // reduced working hours during Ramadan
  openrouterApiKey            String?
  openrouterModel             String   @default("anthropic/claude-3.5-haiku")
  // SaaS subscription
  plan                        String   @default("trial")
  subscriptionStatus          String   @default("active")
  trialEndsAt                 DateTime?
  stripeCustomerId            String?
  stripeSubscriptionId        String?
  // WhatsApp config (encrypted at rest in production)
  whatsappEnabled             Boolean  @default(false)
  whatsappBusinessNumber      String?
  whatsappPhoneNumberId       String?
  whatsappAccessTokenEnc      String?
  whatsappAppSecretEnc        String?
  whatsappVerifyTokenHash     String?
  whatsappGreeting            String?
  whatsappCredentialsUpdatedAt DateTime?
  // P0.3 fix: deletedAt was referenced by tenants/[slug] + companies/[slug]
  // DELETE handlers but was missing from the model — caused 3 pre-existing
  // tsc errors. Adding it here closes all of them and enables proper
  // soft-delete cascade for tenants (5-year financial-record retention).
  deletedAt                   DateTime?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  clients           Client[]
  invoices          Invoice[]
  products          ProductCatalog[]
  purchaseInvoices  PurchaseInvoice[]
  employees         Employee[]
  journalEntries    JournalEntry[]
  accounts          Account[]
  eInvoices         EInvoice[]
  orderDeliveries   OrderDelivery[]
  setupWizard       SetupWizardProgress?
  paymentTxns       PaymentTransaction[]
  aiLogs            AiProcessingLog[]
  invoiceTemplates      InvoiceTemplate[]
  invoiceTemplateSettings InvoiceTemplateSettings?
  warehouses        Warehouse[]
  inventoryItems    InventoryItem[]
  stockMovements    StockMovement[]
  productMatchAudit ProductMatchAudit[]
  productAliases    ProductAlias[]
  matchOverrides    MatchOverride[]

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([subscriptionStatus])
  @@index([plan])
  @@index([deletedAt])
  @@map("companies")
}

model SetupWizardProgress {
  id          Int      @id @default(autoincrement())
  companySlug String   @unique
  currentStep Int      @default(1)
  completed   Boolean  @default(false)
  data        String   @default("{}") // JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companySlug], references: [slug], onDelete: Restrict)

  @@map("setup_wizard_progress")
}

// ────────────────────────────────────────────────────────────────────────────
// Clients
// ────────────────────────────────────────────────────────────────────────────

model Client {
  id          Int      @id @default(autoincrement())
  name        String
  email       String?
  phone       String?
  company     String?
  address     String?
  notes       String?
  companySlug String
  // DB-005 FIX: Soft delete
  deletedAt   DateTime?
  deletedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Company  @relation(fields: [companySlug], references: [slug], onDelete: Restrict)
  invoices Invoice[]

  @@index([companySlug])
  @@index([companySlug, createdAt, id])
  @@index([companySlug, deletedAt])
  @@map("clients")
}

// ────────────────────────────────────────────────────────────────────────────
// Invoices
// ────────────────────────────────────────────────────────────────────────────

model Invoice {
  id              Int      @id @default(autoincrement())
  invoiceNumber   String
  companySlug     String
  clientId        Int?
  clientName      String
  clientEmail     String?
  clientPhone     String?
  clientAddress   String?
  issueDate       String // YYYY-MM-DD
  dueDate         String
  status          String   @default("draft") // draft | sent | paid | partial | overdue | cancelled
  lineItems       String   @default("[]") // JSON
  subtotal        String   @default("0")
  taxRate         String   @default("0")
  taxAmount       String   @default("0")
  total           String   @default("0")
  shipping        String   @default("0")
  discount        String   @default("0")
  paid            String   @default("0")
  notes           String?
  source          String?
  createdByEmail  String?
  createdByName   String?
  whatsappRawText String?
  parsedConfidence String?
  journalEntryId  Int?
  eInvoiceStatus  String?
  deliveryMethod  String?
  version         Int      @default(0) // optimistic lock
  // DB-005 FIX: Soft delete for financial records
  deletedAt       DateTime?
  deletedBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant   Company  @relation(fields: [companySlug], references: [slug], onDelete: Restrict)
  client   Client?  @relation(fields: [clientId], references: [id])
  eInvoice EInvoice?
  delivery OrderDelivery?

  @@unique([companySlug, invoiceNumber])
  @@index([companySlug])
  @@index([companySlug, issueDate])
  @@index([companySlug, status])
  @@index([clientId])
  @@index([companySlug, createdAt, id])
  @@index([journalEntryId])
  @@index([companySlug, eInvoiceStatus])
  @@index([companySlug, deletedAt])
  @@index([companySlug, dueDate, status])
  // H4 FIX: additional indexes for frequently queried fields
  @@index([invoiceNumber])
  @@index([status])
  @@map("invoices")
}

// ────────────────────────────────────────────────────────────────────────────
// Product Catalog
// ────────────────────────────────────────────────────────────────────────────

model ProductCatalog {
  id            Int      @id @default(autoincrement())
  code          String?
  name          String
  aliases       String   @default("[]") // JSON
  purchasePrice String?
  sellingPrice  String?
  wholesalePrice String?
  companySlug   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Company @relation(fields: [companySlug], references: [slug], onDelete: Restrict)
  inventoryItems InventoryItem[]
  productAliases ProductAlias[]
  stockMovements StockMovement[]

  @@index([companySlug])
  @@index([companySlug, createdAt, id])
  @@map("product_catalog")
}

// ────────────────────────────────────────────────────────────────────────────
// Inventory (Warehouses + Stock Items) — P2-D
// ────────────────────────────────────────────────────────────────────────────

model Warehouse {
  id          Int      @id @default(autoincrement())
  companySlug String
  name        String
  code        String
  address     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Company  @relation(fields: [companySlug], references: [slug], onDelete: Restrict)
  items       InventoryItem[]
  stockMovements StockMovement[]
  @@index([companySlug])
  @@index([companySlug, isActive])
  @@unique([companySlug, code])
  @@map("warehouses")
}

model InventoryItem {
  id          Int      @id @default(autoincrement())
  companySlug String
  warehouseId Int
  productId   Int
  quantity    String   @default("0")
  reorderLevel String  @default("0")
  reorderQty  String   @default("0")
  batchNumber String?
  expiryDate  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  warehouse   Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product     ProductCatalog @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant      Company        @relation(fields: [companySlug], references: [slug], onDelete: Restrict)
  @@unique([warehouseId, productId])
  @@index([companySlug])
  @@index([productId])
  @@index([warehouseId])
  @@map("inventory_items")
}

model StockMovement {
  id           Int      @id @default(autoincrement())
  companySlug  String
  productId    Int?
  warehouseId  Int
  qty          String
  sourceType   String
  sourceId     Int?
  note         String?
  createdBy    String   @default("system")
  createdAt    DateTime @default(now())

  tenant      Company        @relation(fields: [companySlug], references: [slug], onDelete: Restrict)
  product     ProductCatalog? @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([companySlug, createdAt])
  @@index([companySlug, productId])
  @@index([sourceType, sourceId])
  @@index([warehouseId])
  // H4 FIX: additional indexes for frequently queried fields
  @@index([companySlug])
  @@index([productId])
  @@map("stock_movements")
}

// ────────────────────────────────────────────────────────────────────────────
// Purchases
// ────────────────────────────────────────────────────────────────────────────

model PurchaseInvoice {
  id              Int      @id @default(autoincrement())
  num             String
  date            String
  supplier        String   @default("")
  companySlug     String
  items           String   @default("[]") // JSON
  sourceInvoiceIds String  @default("[]") // JSON
  totalQty        Int      @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  deletedAt       DateTime?
  deletedBy       String?

  tenant Company @relation(fields: [companySlug], references: [slug], onDelete: Restrict)

  @@index([companySlug])
  @@index([companySlug, createdAt, id])
  @@index([companySlug, deletedAt])
  @@map("purchase_invoices")
}

// ────────────────────────────────────────────────────────────────────────────
// HR Module
// ────────────────────────────────────────────────────────────────────────────

model Employee {
  id            Int      @id @default(autoincrement())
  companySlug   String
  name          String
  nameEn        String?
  phone         String?
  email         String?
  position      String?
  department    String?
  baseSalary    String   @default("0") // الراتب الأساسي (for gratuity calc)
  allowances    String   @default("0") // البدلات (housing, transport, etc.)
  currency      String   @default("KWD")
  joinDate      String?
  endDate       String? // تاريخ انتهاء الخدمة (for gratuity calc)
  isActive      Boolean  @default(true)
  notes         String?
  // Gulf-specific fields
  civilId       String? // الرقم المدني (Kuwait Civil ID - PacI)
  nationality   String? // الجنسية
  residenceExpiry String? // تاريخ انتهاء الإقامة (YYYY-MM-DD)
  passportNumber String? // رقم الجواز
  bankAccount   String? // رقم الحساب البنكي (for salary transfer)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant       Company      @relation(fields: [companySlug], references: [slug], onDelete: Restrict)
  attendance   Attendance[]
  salaries     Salary[]
  commissions  Commission[]
  leaveReqs    LeaveRequest[]
  performances Performance[]

  @@index([companySlug])
  @@index([civilId])
  @@index([companySlug, isActive])
  @@map("hr_employees")
}

model Attendance {
  id          Int      @id @default(autoincrement())
  companySlug String
  employeeId  Int
  date        String
  status      String   @default("present") // present | absent | late | half | remote
  checkIn     String?
  checkOut    String?
  notes       String?
  createdAt   DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companySlug])
  @@index([employeeId, date])
  @@index([companySlug, date])
  @@map("hr_attendance")
}

model Salary {
  id          Int      @id @default(autoincrement())
  companySlug String
  employeeId  Int
  month       String // "2025-06"
  baseSalary  String   @default("0")
  allowances  String   @default("0")
  deductions  String   @default("0")
  bonus       String   @default("0")
  netSalary   String   @default("0")
  isPaid      Boolean  @default(false)
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companySlug])
  @@index([employeeId, month])
  @@index([companySlug, isPaid])
  @@index([companySlug, month])
  @@map("hr_salaries")
}

model Commission {
  id          Int      @id @default(autoincrement())
  companySlug String
  employeeId  Int
  date        String
  type        String   @default("sales") // sales | referral | target | other
  description String?
  amount      String   @default("0")
  isPaid      Boolean  @default(false)
  createdAt   DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companySlug])
  @@index([employeeId])
  @@index([companySlug, isPaid])
  @@index([companySlug, date])
  @@map("hr_commissions")
}

model LeaveRequest {
  id          Int      @id @default(autoincrement())
  companySlug String
  employeeId  Int
  type        String   @default("annual") // annual | sick | unpaid | maternity | other
  startDate   String
  endDate     String
  days        Int      @default(1)
  reason      String?
  status      String   @default("pending") // pending | approved | rejected
  approvedBy  String?
  createdAt   DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companySlug])
  @@index([employeeId])
  @@index([companySlug, status])
  @@map("hr_leave_requests")
}

model Performance {
  id            Int      @id @default(autoincrement())
  companySlug   String
  employeeId    Int
  period        String // "2025-Q2"
  kpiScore      Int?
  attendScore   Int?
  teamScore     Int?
  overallScore  Int?
  rating        String?
  strengths     String?
  improvements  String?
  reviewerNote  String?
  createdAt     DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companySlug])
  @@index([employeeId])
  @@index([companySlug, period])
  @@map("hr_performance")
}

// ────────────────────────────────────────────────────────────────────────────
// Accounting
// ────────────────────────────────────────────────────────────────────────────

model Account {
  id          Int      @id @default(autoincrement())
  code        String
  nameAr      String
  nameEn      String?
  type        String // asset | liability | equity | revenue | expense | contra_revenue | contra_asset
  parentId    Int?
  companySlug String
  balance     String   @default("0")
  currency    String   @default("KWD")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent        Account?          @relation("AccountParent", fields: [parentId], references: [id])
  children      Account[]         @relation("AccountParent")
  journalLines  JournalEntryLine[]
  tenant        Company           @relation(fields: [companySlug], references: [slug], onDelete: Restrict)

  @@index([companySlug])
  @@index([code])
  @@unique([companySlug, code])
  @@index([parentId])
  @@index([companySlug, type])
  @@index([companySlug, isActive])
  @@map("accounts")
}

model JournalEntry {
  id          Int      @id @default(autoincrement())
  date        String   // YYYY-MM-DD
  description String?
  reference   String?
  companySlug String
  createdBy   String
  status      String   @default("draft") // draft | posted | reversed
  sourceType  String?
  sourceId    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  deletedBy   String?

  tenant Company             @relation(fields: [companySlug], references: [slug], onDelete: Restrict)
  lines   JournalEntryLine[]

  @@index([companySlug])
  @@index([companySlug, date])
  @@index([companySlug, deletedAt])
  @@index([companySlug, status])
  @@index([companySlug, sourceType, sourceId])
  @@map("journal_entries")
}

model JournalEntryLine {
  id         Int      @id @default(autoincrement())
  entryId    Int
  accountId  Int
  debit      String   @default("0")
  credit     String   @default("0")
  description String?
  createdAt  DateTime @default(now())

  entry   JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([entryId])
  @@index([accountId])
  @@map("journal_entry_lines")
}

// ────────────────────────────────────────────────────────────────────────────
// E-Invoicing
// ────────────────────────────────────────────────────────────────────────────

model EInvoice {
  id               Int      @id @default(autoincrement())
  invoiceId        Int      @unique
  companySlug      String
  authorityType    String   @default("none") // none | zatca | uae_fta | bahrain_nbr | oman_tax | kuwait_future
  submissionStatus String   @default("pending") // pending | submitted | approved | rejected
  uuid             String?
  xmlHash          String?
  signedXml        String?
  rawXml           String?
  rejectionReason  String?
  submittedAt      DateTime?
  approvedAt       DateTime?
  retryCount       Int      @default(0)
  lastRetryAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?
  deletedBy        String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenant  Company @relation(fields: [companySlug], references: [slug])

  @@index([invoiceId])
  @@index([companySlug])
  @@index([companySlug, submissionStatus])
  @@index([companySlug, deletedAt])
  @@map("e_invoices")
}

// ────────────────────────────────────────────────────────────────────────────
// Order Deliveries
// ────────────────────────────────────────────────────────────────────────────

model OrderDelivery {
  id            Int      @id @default(autoincrement())
  invoiceId     Int?     @unique
  companySlug   String
  clientName    String?
  clientPhone   String?
  address       String?
  locationUrl   String?
  preferredTime DateTime?
  deliveryFee   String   @default("0")
  status        String   @default("Pending") // Pending | Assigned | Delivered | Cancelled
  driverId      String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant  Company  @relation(fields: [companySlug], references: [slug], onDelete: Restrict)
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  driver  User?    @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@index([companySlug])
  @@index([companySlug, status])
  @@index([companySlug, preferredTime])
  @@index([driverId])
  @@map("order_deliveries")
}

// ────────────────────────────────────────────────────────────────────────────
// Payments & SaaS Billing
// ────────────────────────────────────────────────────────────────────────────

model PaymentProviderConfig {
  provider              String   @id // 'stripe' | 'paymob'
  encryptedCredentials  String?
  publicConfig          String?
  credentialsUpdatedAt  DateTime?
  updatedBy             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now())

  @@map("payment_provider_configs")
}

model PaymentTransaction {
  id                Int      @id @default(autoincrement())
  companySlug       String
  plan              String
  method            String // stripe_card | paymob_wallet | paymob_meeza | paymob_card
  provider          String // stripe | paymob
  amount            String   @default("0")
  currency          String   @default("EGP")
  status            String   @default("pending") // pending | paid | failed | cancelled
  providerPaymentId String?
  providerOrderId   String?
  providerEventId   String?
  checkoutUrl       String?
  failureReason     String?
  metadata          String? // JSON
  createdBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now())
  deletedAt         DateTime?
  deletedBy         String?

  tenant Company @relation(fields: [companySlug], references: [slug])

  @@unique([provider, providerEventId])
  @@index([provider, providerPaymentId])
  @@index([companySlug])
  @@index([companySlug, deletedAt])
  @@index([companySlug, status])
  @@index([companySlug, createdAt])
  @@index([provider])
  @@map("payment_transactions")
}

model PaymentsVault {
  id          String   @id @default("singleton")
  wrappedKey  String
  kdfSalt     String
  kdfN        Int      @default(16384)
  fingerprint String
  algo        String   @default("aes-256-gcm")
  createdBy   String?
  createdAt   DateTime @default(now())
  rotatedAt   DateTime?
  rotatedBy   String?

  @@map("payments_vault")
}

// ────────────────────────────────────────────────────────────────────────────
// Permissions & RBAC
// ────────────────────────────────────────────────────────────────────────────

model Permission {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  labelAr     String
  labelEn     String?
  category    String   @default("general")
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@index([category])
  @@map("permissions")
}

model RolePermission {
  id            Int      @id @default(autoincrement())
  role          String
  permissionKey String
  companySlug   String?
  value         Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt


// Garfix v12 — Prisma schema
// Multi-tenant SaaS ERP/Invoicing platform
//
// ─────────────────────────────────────────────────────────────────────────────
// UNIFIED POSTGRESQL CONFIGURATION (All Environments)
// ─────────────────────────────────────────────────────────────────────────────
// This project uses PostgreSQL in ALL environments:
//   - Development: Docker Compose or Neon serverless
//   - CI/CD: GitHub Actions with postgres:16-alpine service
//   - Production: Managed PostgreSQL (Neon, RDS, or Supabase)
//
// SQLite has been REMOVED as it's unsuitable for multi-tenant SaaS:
//   - No concurrent writes under load
//   - No connection pooling
//   - No read replicas
//   - WAL mode is a workaround, not a solution
//
// Migration from SQLite to PostgreSQL required NO model changes because
// the schema was already PostgreSQL-compatible (String for money/JSON).
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

// ── UNIFIED POSTGRESQL (all environments) ────────────────────────────────
// EA-002 FIX: Switched from SQLite to PostgreSQL universally.
// All environments now use PostgreSQL for consistency and reliability.
// H1 FIX: directUrl enables Prisma Studio / migrate deploy to use a direct
// connection while the app uses pooled URL.
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // H1 FIX: directUrl for Prisma Studio / migrate deploy
  // REQUIRED: Set DATABASE_DIRECT_URL in all environments (see .env.example)
  directUrl = env("DATABASE_DIRECT_URL")
}

// ── SQLite removed — kept for reference only ────────────────────────────────
// datasource db {
//   provider = "sqlite"
//   url      = env("DATABASE_URL")
// }

// ────────────────────────────────────────────────────────────────────────────
// Users & Auth
// ────────────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  uid           String   @unique
  email         String   @unique
  passwordHash  String
  displayName   String
  role          String   @default("employee") // admin | editor | employee | viewer
  companies     String   @default("[]") // JSON array of company slugs
  permissions   String   @default("{}") // JSON map
  tokenVersion  Int      @default(0)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  chatHistory       ChatMessage[]
  emailVerifications EmailVerification[]
  orderDeliveries   OrderDelivery[]
  auditLogs         AuditLog[]
  mfaSecrets        MFASecret[]
  sessions          SessionRegistry[]

  @@index([role])
  @@map("app_users")
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String
  token     String?  @unique
  codeHash  String?
  purpose   String   @default("email_verify") // email_verify | password_reset
  attempts  Int      @default(0)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [uid], onDelete: Restrict)

  @@index([userId, purpose, createdAt])
  @@map("email_verifications")
}

// ────────────────────────────────────────────────────────────────────────────
// Companies (Tenants)
// ────────────────────────────────────────────────────────────────────────────

model Company {
  id                          Int      @id @default(autoincrement())
  name                        String
  slug                        String   @unique
  logoBase64                  String?  // EA-013 DEPRECATED: Use storage.ts instead. This column will be removed in a future migration.
  nameAr                      String?
  emoji                       String?
  color                       String?
  phone                       String?
  email                       String?
  address                     String?
  vatNumber                   String?
  commercialRegistration      String? // السجل التجاري (Kuwait CR number)
  currency                    String   @default("KWD")
  country                     String? // KW | SA | AE | BH | OM | QA
  timezone                    String?
  defaultTaxRate              String   @default("0")
  // Gulf-specific settings
  weekendDays                 String   @default("[5,6]") // JSON array: 5=Fri, 6=Sat (Gulf weekend)
  ramadanHours                Boolean  @default(false) // reduced working hours during Ramadan
  openrouterApiKey            String?
  openrouterModel             String   @default("anthropic/claude-3.5-haiku")
  // SaaS subscription
  plan                        String   @default("trial")
  subscriptionStatus          String   @default("active")
  trialEndsAt                 DateTime?
  stripeCustomerId            String?
  stripeSubscriptionId        String?
  // WhatsApp config (encrypted at rest in production)
  whatsappEnabled             Boolean  @default(false)
  whatsappBusinessNumber      String?
  whatsappPhoneNumberId       String?
  whatsappAccessTokenEnc      String?
  whatsappAppSecretEnc        String?
  whatsappVerifyTokenHash     String?
  whatsappGreeting            String?
  whatsappCredentialsUpdatedAt DateTime?
  // P0.3 fix: deletedAt was referenced by tenants/[slug] + companies/[slug]
  // DELETE handlers but was missing from the model — caused 3 pre-existing
  // tsc errors. Adding it here closes all of them and enables proper
  // soft-delete cascade for tenants (5-year financial-record retention).
  deletedAt                   DateTime?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  clients           Client[]
  invoices          Invoice[]
  products          ProductCatalog[]
  purchaseInvoices  PurchaseInvoice[]
  employees         Employee[]
  journalEntries    JournalEntry[]
  accounts          Account[]
  eInvoices         EInvoice[]
  orderDeliveries   OrderDelivery[]
  setupWizard       SetupWizardProgress?
  paymentTxns       PaymentTransaction[]
  aiLogs            AiProcessingLog[]
  invoiceTemplates      InvoiceTemplate[]
  invoiceTemplateSettings InvoiceTemplateSettings?
  warehouses        Warehouse[]
  inventoryItems    InventoryItem[]
  stockMovements    StockMovement[]
  productMatchAudit ProductMatchAudit[]
  productAliases    ProductAlias[]
  matchOverrides    MatchOverride[]
  runtime           CompanyRuntime?
  attendances       Attendance[]
  salaries           Salary[]
  commissions        Commission[]
  leaveRequests      LeaveRequest[]
  performances       Performance[]
  automationRules    AutomationRule[]
  notifications      Notification[]
  suppliers          Supplier[]
  salesReturns       SalesReturn[]
  purchaseReturns    PurchaseReturn[]

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([subscriptionStatus])
  @@index([plan])
  @@index([deletedAt])
  @@map("companies")
}

model SetupWizardProgress {
  id          Int      @id @default(autoincrement())
  companySlug String   @unique
  currentStep Int      @default(1)
  completed   Boolean  @default(false)
  data        String   @default("{}") // JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companySlug], references: [slug], onDelete: Restrict)

  @@map("setup_wizard_progress")
}

// ────────────────────────────────────────────────────────────────────────────
// Clients
// ────────────────────────────────────────────────────────────────────────────

model Client {
  id          Int      @id @default(autoincrement())
  name        String
  email       String?
  phone       String?
  company     String?
  address     String?
  notes       String?
  companySlug String
  // DB-005 FIX: Soft delete
  deletedAt   DateTime?
  deletedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Company  @relation(fields: [companySlug], references: [slug], onDelete: Restrict)
  invoices Invoice[]

  @@index([companySlug, createdAt, id])
  @@index([companySlug, deletedAt])
  @@map("clients")
}

// ────────────────────────────────────────────────────────────────────────────
// Invoices
// ────────────────────────────────────────────────────────────────────────────

model Invoice {
  id              Int      @id @default(autoincrement())
  invoiceNumber   String
  companySlug     String
  clientId        Int?
  clientName      String
  clientEmail     String?
  clientPhone     String?
  clientAddress   String?
  issueDate       String // YYYY-MM-DD
  dueDate         String
  status          String   @default("draft") // draft | sent | paid | partial | overdue | cancelled
  lineItems       String   @default("[]") // JSON
  subtotal        String   @default("0")
  taxRate         String   @default("0")
  taxAmount       String   @default("0")
  total           String   @default("0")
  shipping        String   @default("0")
  discount        String   @default("0")
  paid            String   @default("0")
  notes           String?
  source          String?
  createdByEmail  String?
  createdByName   String?
  whatsappRawText String?
  parsedConfidence String?
  journalEntryId  Int?
  eInvoiceStatus  String?
  deliveryMethod  String?
  version         Int      @default(0) // optimistic lock
  // DB-005 FIX: Soft delete for financial records
  deletedAt       DateTime?
  deletedBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant   Company  @relation(fields: [companySlug], references: [slug], onDelete: Restrict)
  client       Client?  @relation(fields: [clientId], references: [id])
  eInvoice     EInvoice?
  delivery     OrderDelivery?
  salesReturns SalesReturn[]

  @@unique([companySlug, invoiceNumber])
  @@index([companySlug, issueDate])
  @@index([companySlug, status])
  @@index([clientId])
  @@index([companySlug, createdAt, id])
  @@index([journalEntryId])
  @@index([companySlug, eInvoiceStatus])
  @@index([companySlug, deletedAt])
  @@index([companySlug, dueDate, status])
  // H4 FIX: additional indexes for frequently queried fields
  @@index([invoiceNumber])
  @@index([status])
  @@map("invoices")
}

// ────────────────────────────────────────────────────────────────────────────
// Product Catalog
// ────────────────────────────────────────────────────────────────────────────

model ProductCatalog {
  id            Int      @id @default(autoincrement())
  code          String?
  name          String
  aliases       String   @default("[]") // JSON
  purchasePrice String?
  sellingPrice  String?
  wholesalePrice String?
  companySlug   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Company @relation(fields: [companySlug], references: [slug], onDelete: Restrict)
  inventoryItems InventoryItem[]
  productAliases ProductAlias[]
  stockMovements StockMovement[]

  @@index([companySlug, createdAt, id])
  @@map("product_catalog")
}

// ────────────────────────────────────────────────────────────────────────────
// Inventory (Warehouses + Stock Items) — P2-D
// ────────────────────────────────────────────────────────────────────────────

model Warehouse {
  id          Int      @id @default(autoincrement())
  companySlug String
  name        String
  code        String
  address     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Company  @relation(fields: [companySlug], references: [slug], onDelete: Restrict)
  items       InventoryItem[]
  stockMovements StockMovement[]
  @@index([companySlug])
  @@index([companySlug, isActive])
  @@unique([companySlug, code])
  @@map("warehouses")
}

model InventoryItem {
  id          Int      @id @default(autoincrement())
  companySlug String
  warehouseId Int
  productId   Int
  quantity    String   @default("0")
  reorderLevel String  @default("0")
  reorderQty  String   @default("0")
  batchNumber String?
  expiryDate  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  warehouse   Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product     ProductCatalog @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant      Company        @relation(fields: [companySlug], references: [slug], onDelete: Restrict)
  @@unique([warehouseId, productId])
  @@index([companySlug])
  @@index([productId])
  @@index([warehouseId])
  @@map("inventory_items")
}

model StockMovement {
  id           Int      @id @default(autoincrement())
  companySlug  String
  productId    Int?
  warehouseId  Int
  qty          String
  sourceType   String
  sourceId     Int?
  note         String?
  createdBy    String   @default("system")
  createdAt    DateTime @default(now())
  // ERP-05 FIX: COGS tracking for cost engine
  unitCost     String?  // cost per unit at time of movement
  totalCost    String?  // qty * unitCost
  costMethod   String?  // "fifo" | "weighted_average" | "specific"

  tenant      Company        @relation(fields: [companySlug], references: [slug], onDelete: Restrict)
  product     ProductCatalog? @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([companySlug, createdAt])
  @@index([companySlug, productId])
  @@index([sourceType, sourceId])
  @@index([warehouseId])
  // H4 FIX: additional indexes for frequently queried fields
  @@index([productId])
  @@index([costMethod])
  @@map("stock_movements")
}

// ERP-05 FIX: Sales & Purchase Returns
model SalesReturn {
  id              Int      @id @default(autoincrement())
  companySlug     String
  invoiceId       Int
  clientId        Int?
  returnDate      String
  reason          String?
  items           String   @default("[]") // JSON: [{productId, qty, unitPrice, returnReason}]
  totalAmount     String   @default("0")
  status          String   @default("pending") // pending | approved | processed | refunded
  refundMethod    String?  // "cash" | "credit_note" | "bank_transfer"
  creditNoteId    Int?
  journalEntryId  Int?     // link to reversal journal entry
  approvedBy      String?
  approvedAt      DateTime?
  notes           String?
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  deletedBy       String?

  tenant        Company       @relation(fields: [companySlug], references: [slug], onDelete: Restrict)
  invoice      Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  @@index([companySlug, createdAt])
  @@index([companySlug, status])
  @@index([invoiceId])
  @@index([clientId])
  @@map("sales_returns")
}

model PurchaseReturn {
  id              Int      @id @default(autoincrement())
  companySlug     String
  purchaseInvoiceId Int?
  supplierId      Int?
  returnDate      String
  reason          String?
  items           String   @default("[]") // JSON: [{productId, qty, unitCost, returnReason}]
  totalAmount     String   @default("0")
  status          String   @default("pending") // pending | approved | processed | credited
  journalEntryId  Int?     // link to reversal journal entry
  approvedBy      String?
  approvedAt      DateTime?
  notes           String?
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  deletedBy       String?

  tenant             Company          @relation(fields: [companySlug], references: [slug], onDelete: Restrict)
  purchaseInvoice    PurchaseInvoice? @relation("PurchaseReturnInvoice", fields: [purchaseInvoiceId], references: [id], onDelete: SetNull)
  supplierEntity     Supplier?        @relation("SupplierReturns", fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([companySlug, createdAt])
  @@index([companySlug, status])
  @@index([purchaseInvoiceId])
  @@index([supplierId])
  @@map("purchase_returns")
}

// ────────────────────────────────────────────────────────────────────────────
// Purchases
// ────────────────────────────────────────────────────────────────────────────

// ERP-05 FIX: Supplier as a proper entity (not inline string in PurchaseInvoice)
model Supplier {
  id            Int      @id @default(autoincrement())
  companySlug   String
  name          String
  nameEn        String?
  phone         String?
  email         String?
  address       String?
  vatNumber     String?
  contactPerson String?
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
  deletedBy     String?

  tenant            Company          @relation(fields: [companySlug], references: [slug], onDelete: Restrict)
  purchaseInvoices  PurchaseInvoice[]

  @@index([companySlug, isActive])
  @@index([companySlug, name])
  @@map("suppliers")
}

model PurchaseInvoice {
  id              Int      @id @default(autoincrement())
  num             String
  date            String
  supplier        String   @default("")
  supplierId      Int?     // ERP-05 FIX: FK to Supplier table (nullable for backward compat)
  companySlug     String
  items           String   @default("[]") // JSON
  sourceInvoiceIds String  @default("[]") // JSON
  totalQty        Int      @default(0)
  totalAmount     String   @default("0")
  notes           String?
  createdAt       DateTime @default(now())
  deletedAt       DateTime?
  deletedBy       String?

  tenant         Company   @relation(fields: [companySlug], references: [slug], onDelete: Restrict)
  supplierEntity Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([companySlug, createdAt, id])
  @@index([companySlug, deletedAt])
  @@index([supplierId])
  @@map("purchase_invoices")
}

// ────────────────────────────────────────────────────────────────────────────
// HR Module
// ────────────────────────────────────────────────────────────────────────────

model Employee {
  id            Int      @id @default(autoincrement())
  companySlug   String
  name          String
  nameEn        String?
  phone         String?
  email         String?
  position      String?
  department    String?
  baseSalary    String   @default("0") // الراتب الأساسي (for gratuity calc)
  allowances    String   @default("0") // البدلات (housing, transport, etc.)
  currency      String   @default("KWD")
  joinDate      String?
  endDate       String? // تاريخ انتهاء الخدمة (for gratuity calc)
  isActive      Boolean  @default(true)
  notes         String?
  // Gulf-specific fields
  civilId       String? // الرقم المدني (Kuwait Civil ID - PacI)
  nationality   String? // الجنسية
  residenceExpiry String? // تاريخ انتهاء الإقامة (YYYY-MM-DD)
  passportNumber String? // رقم الجواز
  bankAccount   String? // رقم الحساب البنكي (for salary transfer)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant       Company      @relation(fields: [companySlug], references: [slug], onDelete: Restrict)
  attendance   Attendance[]
  salaries     Salary[]
  commissions  Commission[]
  leaveReqs    LeaveRequest[]
  performances Performance[]

  @@index([civilId])
  @@index([companySlug, isActive])
  @@map("hr_employees")
}

model Attendance {
  id          Int      @id @default(autoincrement())
  companySlug String
  employeeId  Int
  date        String
  status      String   @default("present") // present | absent | late | half | remote
  checkIn     String?
  checkOut    String?
  notes       String?
  createdAt   DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tenant  Company  @relation(fields: [companySlug], references: [slug], onDelete: Restrict)

  @@index([employeeId, date])
  @@index([companySlug, date])
  @@map("hr_attendance")
}

model Salary {
  id          Int      @id @default(autoincrement())
  companySlug String
  employeeId  Int
  month       String // "2025-06"
  baseSalary  String   @default("0")
  allowances  String   @default("0")
  deductions  String   @default("0")
  bonus       String   @default("0")
  netSalary   String   @default("0")
  isPaid      Boolean  @default(false)
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tenant  Company  @relation(fields: [companySlug], references: [slug], onDelete: Restrict)

  @@index([employeeId, month])
  @@index([companySlug, isPaid])
  @@index([companySlug, month])
  @@map("hr_salaries")
}

model Commission {
  id          Int      @id @default(autoincrement())
  companySlug String
  employeeId  Int
  date        String
  type        String   @default("sales") // sales | referral | target | other
  description String?
  amount      String   @default("0")
  isPaid      Boolean  @default(false)
  createdAt   DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tenant  Company  @relation(fields: [companySlug], references: [slug], onDelete: Restrict)

  @@index([employeeId])
  @@index([companySlug, isPaid])
  @@index([companySlug, date])
  @@map("hr_commissions")
}

model LeaveRequest {
  id          Int      @id @default(autoincrement())
  companySlug String
  employeeId  Int
  type        String   @default("annual") // annual | sick | unpaid | maternity | other
  startDate   String
  endDate     String
  days        Int      @default(1)
  reason      String?
  status      String   @default("pending") // pending | approved | rejected
  approvedBy  String?
  createdAt   DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companySlug])
  @@index([employeeId])
  @@index([companySlug, status])
  @@map("hr_leave_requests")
}

model Performance {
  id            Int      @id @default(autoincrement())
  companySlug   String
  employeeId    Int
  period        String // "2025-Q2"
  kpiScore      Int?
  attendScore   Int?
  teamScore     Int?
  overallScore  Int?
  rating        String?
  strengths     String?
  improvements  String?
  reviewerNote  String?
  createdAt     DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companySlug])
  @@index([employeeId])
  @@index([companySlug, period])
  @@map("hr_performance")
}

// ────────────────────────────────────────────────────────────────────────────
// Accounting
// ────────────────────────────────────────────────────────────────────────────

model Account {
  id          Int      @id @default(autoincrement())
  code        String
  nameAr      String
  nameEn      String?
  type        String // asset | liability | equity | revenue | expense | contra_revenue | contra_asset
  parentId    Int?
  companySlug String
  balance     String   @default("0")
  currency    String   @default("KWD")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent        Account?          @relation("AccountParent", fields: [parentId], references: [id])
  children      Account[]         @relation("AccountParent")
  journalLines  JournalEntryLine[]
  tenant        Company           @relation(fields: [companySlug], references: [slug], onDelete: Restrict)

  @@index([companySlug])
  @@index([code])
  @@unique([companySlug, code])
  @@index([parentId])
  @@index([companySlug, type])
  @@index([companySlug, isActive])
  @@map("accounts")
}

model JournalEntry {
  id          Int      @id @default(autoincrement())
  date        String   // YYYY-MM-DD
  description String?
  reference   String?
  companySlug String
  createdBy   String
  status      String   @default("draft") // draft | posted | reversed
  sourceType  String?
  sourceId    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  deletedBy   String?

  tenant Company             @relation(fields: [companySlug], references: [slug], onDelete: Restrict)
  lines   JournalEntryLine[]

  @@index([companySlug])
  @@index([companySlug, date])
  @@index([companySlug, deletedAt])
  @@index([companySlug, status])
  @@index([companySlug, sourceType, sourceId])
  @@map("journal_entries")
}

model JournalEntryLine {
  id         Int      @id @default(autoincrement())
  entryId    Int
  accountId  Int
  debit      String   @default("0")
  credit     String   @default("0")
  description String?
  createdAt  DateTime @default(now())

  entry   JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([entryId])
  @@index([accountId])
  @@map("journal_entry_lines")
}

// ────────────────────────────────────────────────────────────────────────────
// E-Invoicing
// ────────────────────────────────────────────────────────────────────────────

model EInvoice {
  id               Int      @id @default(autoincrement())
  invoiceId        Int      @unique
  companySlug      String
  authorityType    String   @default("none") // none | zatca | uae_fta | bahrain_nbr | oman_tax | kuwait_future
  submissionStatus String   @default("pending") // pending | submitted | approved | rejected
  uuid             String?
  xmlHash          String?
  signedXml        String?
  rawXml           String?
  rejectionReason  String?
  submittedAt      DateTime?
  approvedAt       DateTime?
  retryCount       Int      @default(0)
  lastRetryAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?
  deletedBy        String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenant  Company @relation(fields: [companySlug], references: [slug], onDelete: Restrict)

  @@index([invoiceId])
  @@index([companySlug])
  @@index([companySlug, submissionStatus])
  @@index([companySlug, deletedAt])
  @@map("e_invoices")
}

// ────────────────────────────────────────────────────────────────────────────
// Order Deliveries
// ────────────────────────────────────────────────────────────────────────────

model OrderDelivery {
  id            Int      @id @default(autoincrement())

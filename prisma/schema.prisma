// ═══════════════════════════════════════════════════════════════════════════════
// E-Invoicing Models (P0-7: ZATCA/MENA compliance)
// ═══════════════════════════════════════════════════════════════════════════════

// ─── E-Invoice (matches db.eInvoice) ───

model EInvoice {
  id                String   @id @default(cuid())
  invoiceId         Int      @unique
  authorityType     String   @default("none") // none, zatca, uae_fta, bahrain_nbr, oman_tax, kuwait_decree_10_2026, eta_egypt
  submissionStatus  String   @default("pending") // pending, submitted, accepted, rejected, cleared
  uuid              String?
  xmlHash           String?
  signedXml         String?
  rawXml            String?
  qrCodeBase64      String?  // P0-7: ZATCA TLV QR
  rejectionReason   String?
  submittedAt       DateTime?
  clearedAt         DateTime?
  companySlug       String   @default("default")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  invoice           Invoice  @relation(fields: [invoiceId], references: [id])
}

// ─── ZATCA Certificate (matches db.zatcaCertificate) ───

model ZatcaCertificate {
  id                String   @id @default(cuid())
  companySlug       String
  certificateType   String   // csid, ccd
  certificateDataEnc String?  // AES-256-GCM encrypted X.509 PEM
  privateKeyDataEnc  String?  // AES-256-GCM encrypted private key
  serialNumber      String?
  expiryDate        DateTime?
  status            String   @default("active") // active, expired, revoked, pending
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  @@unique([companySlug, certificateType])
}


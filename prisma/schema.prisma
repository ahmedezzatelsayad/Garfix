// ────────────────────────────────────────────────────────────────────────────

model ProductAlias {
  id                Int      @id @default(autoincrement())
  productCatalogId  Int
  companySlug       String
  alias             String
  language          String   @default("unspecified")
  source            String   @default("manual")
  confidence        Float    @default(1.0)
  isVerified        Boolean  @default(false)
  createdBy         String   @default("system")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product ProductCatalog @relation(fields: [productCatalogId], references: [id], onDelete: Cascade)
  tenant  Company         @relation(fields: [companySlug], references: [slug], onDelete: Restrict)

  @@unique([companySlug, alias])
  @@index([companySlug])
  @@index([productCatalogId])
  @@map("product_aliases")
}

model ProductMatchAudit {
  id           Int      @id @default(autoincrement())
  companySlug  String
  inputText    String
  matchedProductId Int?
  matchedAlias String?
  confidence   Float
  tier         String
  action       String
  isUndone     Boolean  @default(false)
  undoneBy     String?
  undoneAt     DateTime?
  invoiceId    Int?
  createdBy    String   @default("system")
  createdAt    DateTime @default(now())

  // ── Task 17a: AI resolution tracking ───────────────────────────────────────
  // resolvedBy: who made the final decision — "ai" (OpenRouter/z-ai), "human"
  // (admin confirmed via review queue), "auto" (deterministic matcher tier 1/2/3),
  // or null for legacy entries created before this column existed.
  resolvedBy   String?
  // aiReasoning: the reasoning_ar text returned by the AI model — null if the
  // entry was not AI-resolved (legacy/auto/human).
  aiReasoning  String?
  // aiModel: "{provider}/{model}" used for the call, e.g. "openrouter/deepseek/deepseek-r1"
  // or "z-ai/z-ai-glm". Null for non-AI entries. Used for monitoring overturn rate
  // per model in the first two weeks of production usage.
  aiModel      String?

  tenant Company @relation(fields: [companySlug], references: [slug], onDelete: Restrict)

  @@index([companySlug, createdAt])
  @@index([companySlug, isUndone])
  @@index([companySlug, resolvedBy])
  @@map("product_match_audit")
}

/// Learning Engine — records when a human employee overrides the matcher's
/// chosen candidate (e.g. matcher picked candidates[0] but employee confirmed
/// candidates[1]). These overrides feed back into the `historicalMatch` evidence
/// signal so the matcher LEARNS from human corrections over time.
///
/// Lifecycle:
///   1. matcher returns candidates[0] as winner (productId=A)
///   2. employee reviews, decides productId=B (candidates[1]) is correct
///   3. POST /api/products/match-override records:
///        inputText, inputNormalized, fromProductId=A, toProductId=B,
///        chosenAlias, auditId (link to original ProductMatchAudit decision)
///   4. Next time the SAME normalized input is matched, the matcher sees a past
///      override and boosts confidence for productId=B's aliases.
///
/// `inputNormalized` is the Arabic-normalized form (via normalizeArabic) so that
/// minor spelling variations still hit the same override record. The compound
/// index `(companySlug, inputNormalized)` is the primary lookup path.
model MatchOverride {
  id              Int      @id @default(autoincrement())
  companySlug     String
  inputText       String   // raw invoice line description that was overridden
  inputNormalized String   // normalizeArabic(inputText) — fast exact re-lookup
  fromProductId   Int?     // matcher's original winner (null if matcher said "new")
  toProductId     Int      // product the employee chose instead
  chosenAlias     String?  // alias text the employee confirmed
  auditId         Int?     // link to ProductMatchAudit row of the original decision
  reason          String?  // optional employee note ("brand mismatch", "wrong size")
  overriddenBy    String   // user email/id
  createdAt       DateTime @default(now())

  tenant Company @relation(fields: [companySlug], references: [slug], onDelete: Restrict)

  @@index([companySlug, inputNormalized])
  @@index([companySlug, toProductId])
  @@map("match_overrides")
}

/// Task 18a — DB-backed persistent job queue.
///
/// Replaces the in-memory-only job runner for jobs that MUST survive server
/// restarts (specifically the AI Product Match Resolver, which is enqueued
/// inside the invoice sync transaction and must complete even if the server
/// crashes between enqueue and execution).
///
/// SQLite-compatible (no Postgres-specific features). The compound index
/// `(queue, status, scheduledAt)` is the primary polling index used by
/// `recoverPendingJobs()` and the worker loop.
model JobQueue {
  id          Int      @id @default(autoincrement())
  queue       String   // queue name (e.g. "ai-jobs")
  type        String   // job type (e.g. "ai-product-match-resolve")
  data        String   // JSON-serialized payload
  status      String   @default("pending") // pending | running | completed | failed | dead-letter
  attempts    Int      @default(0)
  maxAttempts Int      @default(3)
  lastError   String?
  lockedAt    DateTime?
  lockedBy    String?  // worker ID (process-unique)
  scheduledAt DateTime @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([queue, status, scheduledAt])
  @@index([status, scheduledAt])
  @@map("job_queue")
}

// ────────────────────────────────────────────────────────────────────────────
// AI Orchestration Layer — Model Registry + Benchmark Results
//
// Replaces the "hardcoded provider chain" with a live, self-tuning registry.
// Each model declares which capabilities it supports (chat, invoice-extraction,
// reasoning, vision). A periodic auto-benchmark measures success rate, latency,
// and response quality per (model × capability), then rolls those metrics into
// a single 0-10 `healthScore`. The Smart Router picks the highest-scoring
// healthy model for the requested capability at request time — so the system
// never hard-binds to a model name that might disappear next month.
// ────────────────────────────────────────────────────────────────────────────

model AIModelRegistry {
  id              Int      @id @default(autoincrement())
  provider        String   // openrouter | z-ai | anthropic | openai | gemini | custom
  model           String   // e.g. "tencent/hy3:free", "z-ai-glm"
  displayName     String   // human-friendly label for the dashboard
  capabilities    String   @default("[]") // JSON array: ["chat","invoice-extraction","reasoning","vision"]
  tier            String   @default("free") // "free" | "paid"
  costPer1kIn     Float    @default(0)  // USD per 1k input tokens
  costPer1kOut    Float    @default(0)  // USD per 1k output tokens
  maxTokens       Int      @default(4096)
  contextWindow   Int      @default(8192)
  isEnabled       Boolean  @default(true) // founder can disable a model
  isHealthy       Boolean  @default(true) // auto-set false when healthScore < threshold

  // ── Live health metrics (updated by auto-benchmark) ───────────────────────
  healthScore     Float    @default(0)   // 0-10 composite
  successRate     Float    @default(0)   // 0-100 %
  avgLatencyMs    Int      @default(0)
  p95LatencyMs    Int      @default(0)
  avgQualityScore Float    @default(0)   // 0-10 heuristic
  totalBenchmarks Int      @default(0)
  lastBenchmarkAt DateTime?
  lastError       String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  benchmarks AIBenchmarkResult[]

  @@unique([provider, model])
  @@index([isEnabled, isHealthy, healthScore])
  @@index([tier])
  @@map("ai_model_registry")
}

model AIBenchmarkResult {
  id              Int      @id @default(autoincrement())
  modelRegistryId Int
  capability      String   // chat | invoice-extraction | reasoning | vision
  success         Boolean
  latencyMs       Int
  tokensIn        Int      @default(0)
  tokensOut       Int      @default(0)
  responseQuality Float    @default(0)  // 0-10 heuristic score
  responseSample  String?  // truncated response text for manual inspection
  errorMessage    String?
  createdAt       DateTime @default(now())

  model AIModelRegistry @relation(fields: [modelRegistryId], references: [id], onDelete: Cascade)

  @@index([modelRegistryId, createdAt])
  @@index([capability, createdAt])
  @@map("ai_benchmark_results")
}

  @@unique([companySlug, alias])
  @@index([companySlug])
  @@index([productCatalogId])
  @@map("product_aliases")
}

model ProductMatchAudit {
  id           Int      @id @default(autoincrement())
  companySlug  String
  inputText    String
  matchedProductId Int?
  matchedAlias String?
  confidence   Float
  tier         String
  action       String
  isUndone     Boolean  @default(false)
  undoneBy     String?
  undoneAt     DateTime?
  invoiceId    Int?
  createdBy    String   @default("system")
  createdAt    DateTime @default(now())

  // ── Task 17a: AI resolution tracking ───────────────────────────────────────
  // resolvedBy: who made the final decision — "ai" (OpenRouter/z-ai), "human"
  // (admin confirmed via review queue), "auto" (deterministic matcher tier 1/2/3),
  // or null for legacy entries created before this column existed.
  resolvedBy   String?
  // aiReasoning: the reasoning_ar text returned by the AI model — null if the
  // entry was not AI-resolved (legacy/auto/human).
  aiReasoning  String?
  // aiModel: "{provider}/{model}" used for the call, e.g. "openrouter/deepseek/deepseek-r1"
  // or "z-ai/z-ai-glm". Null for non-AI entries. Used for monitoring overturn rate
  // per model in the first two weeks of production usage.
  aiModel      String?

  tenant Company @relation(fields: [companySlug], references: [slug], onDelete: Restrict)

  @@index([companySlug, createdAt])
  @@index([companySlug, isUndone])
  @@index([companySlug, resolvedBy])
  @@map("product_match_audit")
}

/// Learning Engine — records when a human employee overrides the matcher's
/// chosen candidate (e.g. matcher picked candidates[0] but employee confirmed
/// candidates[1]). These overrides feed back into the `historicalMatch` evidence
/// signal so the matcher LEARNS from human corrections over time.
///
/// Lifecycle:
///   1. matcher returns candidates[0] as winner (productId=A)
///   2. employee reviews, decides productId=B (candidates[1]) is correct
///   3. POST /api/products/match-override records:
///        inputText, inputNormalized, fromProductId=A, toProductId=B,
///        chosenAlias, auditId (link to original ProductMatchAudit decision)
///   4. Next time the SAME normalized input is matched, the matcher sees a past
///      override and boosts confidence for productId=B's aliases.
///
/// `inputNormalized` is the Arabic-normalized form (via normalizeArabic) so that
/// minor spelling variations still hit the same override record. The compound
/// index `(companySlug, inputNormalized)` is the primary lookup path.
model MatchOverride {
  id              Int      @id @default(autoincrement())
  companySlug     String
  inputText       String   // raw invoice line description that was overridden
  inputNormalized String   // normalizeArabic(inputText) — fast exact re-lookup
  fromProductId   Int?     // matcher's original winner (null if matcher said "new")
  toProductId     Int      // product the employee chose instead
  chosenAlias     String?  // alias text the employee confirmed
  auditId         Int?     // link to ProductMatchAudit row of the original decision
  reason          String?  // optional employee note ("brand mismatch", "wrong size")
  overriddenBy    String   // user email/id
  createdAt       DateTime @default(now())

  tenant Company @relation(fields: [companySlug], references: [slug], onDelete: Restrict)

  @@index([companySlug, inputNormalized])
  @@index([companySlug, toProductId])
  @@map("match_overrides")
}

/// Task 18a — DB-backed persistent job queue.
///
/// Replaces the in-memory-only job runner for jobs that MUST survive server
/// restarts (specifically the AI Product Match Resolver, which is enqueued
/// inside the invoice sync transaction and must complete even if the server
/// crashes between enqueue and execution).
///
/// SQLite-compatible (no Postgres-specific features). The compound index
/// `(queue, status, scheduledAt)` is the primary polling index used by
/// `recoverPendingJobs()` and the worker loop.
model JobQueue {
  id          Int      @id @default(autoincrement())
  queue       String   // queue name (e.g. "ai-jobs")
  type        String   // job type (e.g. "ai-product-match-resolve")
  data        String   // JSON-serialized payload
  status      String   @default("pending") // pending | running | completed | failed | dead-letter
  attempts    Int      @default(0)
  maxAttempts Int      @default(3)
  lastError   String?
  lockedAt    DateTime?
  lockedBy    String?  // worker ID (process-unique)
  scheduledAt DateTime @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([queue, status, scheduledAt])
  @@index([status, scheduledAt])
  @@map("job_queue")
}

// ────────────────────────────────────────────────────────────────────────────
// AI Orchestration Layer — Model Registry + Benchmark Results
//
// Replaces the "hardcoded provider chain" with a live, self-tuning registry.
// Each model declares which capabilities it supports (chat, invoice-extraction,
// reasoning, vision). A periodic auto-benchmark measures success rate, latency,
// and response quality per (model × capability), then rolls those metrics into
// a single 0-10 `healthScore`. The Smart Router picks the highest-scoring
// healthy model for the requested capability at request time — so the system
// never hard-binds to a model name that might disappear next month.
// ────────────────────────────────────────────────────────────────────────────

model AIModelRegistry {
  id              Int      @id @default(autoincrement())
  provider        String   // openrouter | z-ai | anthropic | openai | gemini | custom
  model           String   // e.g. "tencent/hy3:free", "z-ai-glm"
  displayName     String   // human-friendly label for the dashboard
  capabilities    String   @default("[]") // JSON array: ["chat","invoice-extraction","reasoning","vision"]
  tier            String   @default("free") // "free" | "paid"
  costPer1kIn     Float    @default(0)  // USD per 1k input tokens
  costPer1kOut    Float    @default(0)  // USD per 1k output tokens
  maxTokens       Int      @default(4096)
  contextWindow   Int      @default(8192)
  isEnabled       Boolean  @default(true) // founder can disable a model
  isHealthy       Boolean  @default(true) // auto-set false when healthScore < threshold

  // ── Live health metrics (updated by auto-benchmark) ───────────────────────
  healthScore     Float    @default(0)   // 0-10 composite
  successRate     Float    @default(0)   // 0-100 %
  avgLatencyMs    Int      @default(0)
  p95LatencyMs    Int      @default(0)
  avgQualityScore Float    @default(0)   // 0-10 heuristic
  totalBenchmarks Int      @default(0)
  lastBenchmarkAt DateTime?
  lastError       String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  benchmarks AIBenchmarkResult[]

  @@unique([provider, model])
  @@index([isEnabled, isHealthy, healthScore])
  @@index([tier])
  @@map("ai_model_registry")
}

model AIBenchmarkResult {
  id              Int      @id @default(autoincrement())
  modelRegistryId Int
  capability      String   // chat | invoice-extraction | reasoning | vision
  success         Boolean
  latencyMs       Int
  tokensIn        Int      @default(0)
  tokensOut       Int      @default(0)
  responseQuality Float    @default(0)  // 0-10 heuristic score
  responseSample  String?  // truncated response text for manual inspection
  errorMessage    String?
  createdAt       DateTime @default(now())

  model AIModelRegistry @relation(fields: [modelRegistryId], references: [id], onDelete: Cascade)

  @@index([modelRegistryId, createdAt])
  @@index([capability, createdAt])
  @@map("ai_benchmark_results")
}

// ────────────────────────────────────────────────────────────────────────────
// AI Fabric — Phase 0 Data Model Foundation
//
// These models support the AI Fabric intelligence cascade: every AI request
// passes through cache → pattern → rule → memory → AI, with per-company
// budgeting, cost tracking, and profit measurement. Schema-only in Phase 0;
// business logic is added in subsequent phases.
// ────────────────────────────────────────────────────────────────────────────

/// Per-company runtime configuration for the AI Fabric worker pool.
/// Controls how many concurrent AI workers a company can use and its
/// throttling/paused state. Tier-based defaults are enforced in
/// /lib/ai-fabric/worker-scaler.ts constants, not hardcoded here.
model CompanyRuntime {
  id                   Int      @id @default(autoincrement())
  companyId            Int      @unique
  workerPoolSize       Int      @default(2)
  status               String   @default("active") // active | throttled | paused
  slaTier              String   @default("starter") // enterprise | business | starter (Phase 9)
  maxAcceptableLatencyMs Int    @default(2000) // SLA latency target (Phase 9)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([slaTier])
  @@map("company_runtimes")
}

/// Central log for every AI Fabric request — regardless of which cascade
/// stage resolved it. This is the primary data source for cost optimization
/// metrics (Phase 2), AI Score (Phase 14), and Cost-per-Invoice (Phase 15).
/// Complements (does NOT replace) AIUsageLog, which tracks raw provider
/// calls. AIRequestLog tracks the BUSINESS-LEVEL resolution path.
model AIRequestLog {
  id           Int      @id @default(autoincrement())
  companySlug  String
  requestType  String   // ocr | whatsapp | financial_analysis | matching | other
  resolvedBy   String   // cache | pattern | rule | memory | ai
  provider     String?  // actual model used, e.g. "openrouter/deepseek/deepseek-chat"
  tokensUsed   Int?
  costUsd      Float    @default(0)
  latencyMs    Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([companySlug, createdAt])
  @@index([companySlug, resolvedBy, createdAt])
  @@index([requestType, resolvedBy, createdAt])
  @@index([resolvedBy, createdAt])
  @@map("ai_request_logs")
}

/// Persistent cache entries for the AI Fabric L2 cache layer (Valkey is
/// L1/L2 already, but this table enables auditability, hit-count tracking,
/// and cache analytics that pure Valkey cannot provide). The key is a
/// SHA-256 hash of (companyId + normalized input) to ensure deterministic
/// cache hits across identical requests.
model CacheEntry {
  id         Int      @id @default(autoincrement())
  key        String   @unique // sha256(companyId + normalized input)
  companySlug String
  value      String   // JSON — the cached AI response
  hitCount   Int      @default(0)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companySlug])
  @@index([expiresAt])
  @@map("ai_fabric_cache_entries")
}

/// Per-company AI spending budget configuration. The Budget Engine
/// (Phase 6) increments currentSpendUsd after each AIRequestLog with a
/// cost, and triggers alerts / hard-stop throttling when thresholds are
/// reached. Founder Panel only — not visible to tenants.
model BudgetConfig {
  id                Int      @id @default(autoincrement())
  companySlug       String   @unique
  monthlyBudgetUsd  Float
  currentSpendUsd   Float    @default(0)
  alertThresholdPct Int      @default(80) // alert at 80% of budget
  hardStopEnabled   Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([companySlug])
  @@map("budget_configs")
}

/// Global task-type → provider routing configuration. Unlike AIModelRegistry
/// (which tracks individual model health), this maps business TASK TYPES to
/// their optimal primary + fallback providers. The Provider Optimizer
/// (Phase 3) reads this table to route requests to the right model for
/// the task, with automatic fallback on primary failure.
model ProviderConfig {
  id                Int      @id @default(autoincrement())
  taskType          String   @unique // ocr | whatsapp | financial_analysis | matching | other
  primaryProvider   String   // e.g. "anthropic/claude-3-5-haiku" or "z-ai/z-ai-glm"
  fallbackProvider  String   // fallback when primary fails
  costPerRequestUsd Float?   // estimated average cost per request for this task type
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("provider_configs")
}

/// AI decision memory for the AI Fabric cascade. Unlike AIMemoryNote
/// (which stores human-authored entity notes), AIMemoryEntry stores
/// AI-GENERATED decisions and their context — enabling the cascade to
/// replay previous decisions without re-calling the LLM.
/// Categories: product | customer | invoice | rule | decision
model AIMemoryEntry {
  id             Int      @id @default(autoincrement())
  companySlug    String
  category       String   // product | customer | invoice | rule | decision
  content        String   // JSON — the decision + its context
  createdAt      DateTime @default(now())
  lastAccessedAt DateTime @updatedAt

  @@index([companySlug, category])
  @@index([companySlug, category, lastAccessedAt])
  @@index([lastAccessedAt])
  @@map("ai_memory_entries")
}

/// Periodic profit snapshots for GarfiX itself (not per-tenant).
/// Revenue (from subscription) minus infra cost, AI cost (from
/// AIRequestLog), and worker cost = gross profit. The Profit Engine
/// (Phase 8) computes and stores these snapshots on a daily or
/// on-demand basis. Founder Panel only.
model ProfitSnapshot {
  id            Int      @id @default(autoincrement())
  companySlug   String
  periodStart   DateTime
  periodEnd     DateTime
  revenueUsd    Float    @default(0)
  infraCostUsd  Float    @default(0)
  aiCostUsd     Float    @default(0)
  workerCostUsd Float    @default(0)
  profitUsd     Float    @default(0)
  createdAt     DateTime @default(now())

  @@index([companySlug, periodStart])
  @@index([periodStart, periodEnd])
  @@map("profit_snapshots")
}

// ────────────────────────────────────────────────────────────────────────────
// AI Fabric — Economics Layer Schema (Phases 9-16)
//
// These models support the Economics Layer: Worker Marketplace, Learning
// Engine, Cross-Company Intelligence, AI Score, and AI Compiler.
// ────────────────────────────────────────────────────────────────────────────

/// Learning Engine candidate — tracks repeated AI decisions that MAY be
/// promotable to deterministic rules (Phase 11).
///
/// When the same normalized input produces the same AI output N times
/// (sampleCount >= threshold) with high consistency (confidence >= 0.95),
/// the candidate is promoted to status='promoted' and a Rule is created.
model RuleCandidate {
  id                Int      @id @default(autoincrement())
  companySlug       String
  requestType       String   // ocr | whatsapp | financial_analysis | matching | other
  patternSignature  String   // hash of normalized inputs grouped together
  sampleCount       Int      @default(0)
  consistentOutput  String   // JSON — the output that appeared in >= 95% of samples
  confidence        Float    @default(0)  // 0-1, percentage of samples matching consistentOutput
  status            String   @default("observing") // observing | promoted | rejected
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([companySlug, status])
  @@index([companySlug, patternSignature])
  @@index([status, confidence])
  @@map("rule_candidates")
}

/// Cross-company de-identified patterns (Phase 12).
///
/// Stores GENERAL patterns (e.g. "Apple Charger → SKU/VAT/Category") stripped
/// of all company-specific data. NO financial data, NO customer data, NO
/// company-identifying information. Only the product name/classification.
///
/// Privacy guarantee: no field in this table can be traced back to any
/// specific company. Only contributingCompaniesCount (an integer) is stored.
model GlobalPattern {
  id                       Int      @id @default(autoincrement())
  patternKey               String   // normalized product name, e.g. "apple charger"
  suggestedSku             String?  // JSON — suggested SKU mapping
  suggestedVatCategory     String?  // suggested VAT category
  suggestedCategory        String?  // JSON — suggested product category
  contributingCompaniesCount Int     @default(0) // COUNT ONLY, no company IDs
  confidence               Float    @default(0)
  lastUpdated              DateTime @updatedAt

  @@unique([patternKey])
  @@index([confidence])
  @@index([lastUpdated])
  @@map("global_patterns")
}

/// AI Score daily snapshot per company (Phase 14).
///
/// Internal metric (Founder Panel only) measuring cascade efficiency.
/// Score 0-100: higher = more requests resolved without AI calls.
/// Triggers Learning Engine and Cost Optimizer when score drops below threshold.
model AIScoreSnapshot {
  id              Int      @id @default(autoincrement())
  companySlug     String
  period          String   // e.g. "2026-07-20" (daily)
  score           Float    @default(0)  // 0-100
  cacheHitPct     Float    @default(0)
  ruleHitPct      Float    @default(0)
  aiCallPct       Float    @default(0)
  avgCostPerRequest Float  @default(0)
  createdAt       DateTime @default(now())

  @@unique([companySlug, period])
  @@index([companySlug, createdAt])
  @@index([score])
  @@map("ai_score_snapshots")
}

/// AI Compiler — compiled rules distilled from repeated AI patterns (Phase 16).
///
/// When the Learning Engine identifies a cluster of AI decisions that can be
/// replaced by deterministic logic (regex, decision tree, extractor), this
/// table stores the compiled rule PENDING HUMAN REVIEW. No compiled rule
/// is ever activated without explicit human approval (reviewedBy + reviewedAt).
///
/// This is the most critical table in the Economics Layer — a wrong compiled
/// rule could silently corrupt business decisions. Human-in-the-loop is
/// MANDATORY for status transitions from pending_review → active.
model CompiledRule {
  id                    Int      @id @default(autoincrement())
  requestType           String   // ocr | whatsapp | financial_analysis | matching | other
  patternDescription    String   // human-readable description of the pattern
  logicType             String   // regex | decision_tree | extractor
  logicDefinition       String   // JSON — the actual compiled logic (regex, tree, etc.)
  accuracyOnHistoricalSample Float @default(0) // measured accuracy (0-1)
  status                String   @default("pending_review") // pending_review | active | rejected
  reviewedBy            String?  // email of the human who approved/rejected
  reviewedAt            DateTime?
  sourceCandidateId     Int?     // link to RuleCandidate that generated this
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([status])
  @@index([requestType, status])
  @@index([accuracyOnHistoricalSample])
  @@map("compiled_rules")
}

model MFASecret {
  id             String   @id @default(cuid())
  userUid        String
  secret         String   /// encrypted TOTP secret (stored via cryptoVault)
  recoveryCodes  String   /// JSON array of hashed recovery codes, encrypted
  enabled        Boolean  @default(true)
  verifiedAt     DateTime?
  lastUsedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userUid], references: [uid], onDelete: Cascade)

  @@index([userUid])
}

model SessionRegistry {
  id         String   @id @default(cuid())
  userUid    String
  jti        String   @unique
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  user       User     @relation(fields: [userUid], references: [uid], onDelete: Cascade)

  @@index([userUid])
  @@index([expiresAt])
}

model TamperEvidenceChain {
  id            String   @id @default(cuid())
  companySlug   String?
  entryId       String   @unique  /// references AuditLog.id or AdminAuditLog.id
  contentHash   String   /// SHA-256 of the entry content at write time
  prevHash      String   /// hash of the previous entry in the chain (null for first)
  chainOrder    Int      @default(0)
  verifiedAt    DateTime?
  isValid       Boolean? /// null = not yet verified, true = chain intact, false = tampered
  createdAt     DateTime @default(now())

  @@index([companySlug])
  @@index([chainOrder])
}

model WebhookEndpoint {
  id          String   @id @default(cuid())
  companySlug String
  url         String
  events      String   /// JSON array of subscribed event types
  secret      String   /// HMAC signing secret (encrypted via cryptoVault)
  isActive    Boolean  @default(true)
  lastPingAt  DateTime?
  failCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deliveries  WebhookDelivery[]

  @@index([companySlug])
}

model WebhookDelivery {
  id          String   @id @default(cuid())
  endpointId  String
  endpoint    WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  eventType   String
  payload     String   /// JSON payload
  statusCode  Int?
  response    String?
  attempts    Int      @default(0)
  maxAttempts Int      @default(3)
  status      String   @default("pending") /// pending / success / failed / retried
  nextRetryAt DateTime?
  createdAt   DateTime @default(now())
  deliveredAt DateTime?

  @@index([endpointId])
  @@index([status])
  @@index([nextRetryAt])
}

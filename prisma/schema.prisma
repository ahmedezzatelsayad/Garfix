// NOTE: Financial fields use Decimal instead of Float for production accuracy.
// SQLite doesn't support Decimal, so in dev it falls back to Float-like behavior.
// For PostgreSQL production, Decimal ensures exact precision (no floating-point errors).
// This prevents issues like 0.1 + 0.2 = 0.30000000000000004

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // Change to "postgresql" for production
  url      = env("DATABASE_URL")
  // NOTE: For Prisma 7+, move url to prisma.config.ts and use adapter/accelerateUrl
  // For current Prisma 6.x, url in datasource is still supported
}

// ──────────────────────────────────────────────────────────────────────────────
// Core Platform Models
// ──────────────────────────────────────────────────────────────────────────────

model AppUser {
  id            String   @id @default(cuid())
  uid           String   @unique
  email         String   @unique
  passwordHash  String
  displayName   String
  role          String   @default("employee")
  companies     String   @default("[]") // JSON array of company slugs
  permissions   String   @default("{}") // JSON object
  tokenVersion  Int      @default(0)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  emailVerifications EmailVerification[]
  sessionRegistries  SessionRegistry[]
  chatHistories      ChatHistory[]
  notifications      Notification[]
  mfaSecrets         MFASecret[]
  userWorkspaceState UserWorkspaceState?

  @@map("app_users")
}

model EmailVerification {
  id        String    @id @default(cuid())
  userId    String
  token     String?   @unique
  codeHash  String?
  purpose   String    @default("email_verify")
  attempts  Int       @default(0)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user AppUser @relation(fields: [userId], references: [uid], onDelete: Cascade)

  @@map("email_verifications")
}

model MFASecret {
  id            String    @id @default(cuid())
  userUid       String
  secret        String
  recoveryCodes String // JSON array
  enabled       Boolean   @default(true)
  verifiedAt    DateTime?
  lastUsedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user AppUser @relation(fields: [userUid], references: [uid], onDelete: Cascade)

  @@map("MFASecret")
}

model SessionRegistry {
  id        String   @id @default(cuid())
  userUid   String
  jti       String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  expiresAt DateTime

  user AppUser @relation(fields: [userUid], references: [uid], onDelete: Cascade)

  @@map("SessionRegistry")
}

model Company {
  id                           Int       @id @default(autoincrement())
  name                         String
  slug                         String    @unique
  logoBase64                   String?
  nameAr                       String?
  emoji                        String?
  color                        String?
  phone                        String?
  email                        String?
  address                      String?
  vatNumber                    String?
  commercialRegistration       String?
  currency                     String    @default("KWD")
  country                      String?
  timezone                     String?
  defaultTaxRate               Decimal   @default(0) // Decimal per migration Step 5
  weekendDays                  String    @default("[5,6]") // JSON array
  ramadanHours                 Boolean   @default(false)
  openrouterApiKey             String?
  openrouterModel              String    @default("anthropic/claude-3.5-haiku")
  plan                         String    @default("trial")
  subscriptionStatus           String    @default("active")
  trialEndsAt                  DateTime?
  stripeCustomerId             String?
  stripeSubscriptionId         String?
  currentBillingCycleEnd       DateTime?
  whatsappEnabled              Boolean   @default(false)
  whatsappBusinessNumber       String?
  whatsappPhoneNumberId        String?
  whatsappAccessTokenEnc       String?
  whatsappAppSecretEnc         String?
  whatsappVerifyTokenHash      String?
  whatsappGreeting             String?
  whatsappCredentialsUpdatedAt DateTime?
  deletedAt                    DateTime?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  accounts                     Account[]
  clients                      Client[]
  suppliers                    Supplier[]
  productCatalogs              ProductCatalog[]
  warehouses                   Warehouse[]
  inventoryItems               InventoryItem[]
  invoices                     Invoice[]
  purchaseInvoices             PurchaseInvoice[]
  journalEntries               JournalEntry[]
  fiscalPeriods                FiscalPeriod[]
  costCenters                  CostCenter[]
  bankAccounts                 BankAccount[]
  quotations                   Quotation[]
  purchaseOrders               PurchaseOrder[]
  fxRevaluations               FxRevaluation[]
  fixedAssets                  FixedAsset[]
  landedCostAllocations        LandedCostAllocation[]
  postDatedChecks              PostDatedCheck[]
  openingBalanceEntries        OpeningBalanceEntry[]
  taxFilings                   TaxFiling[]
  interCompanyTransactionsFrom InterCompanyTransaction[] @relation("InterCompanyFrom")
  interCompanyTransactionsTo   InterCompanyTransaction[] @relation("InterCompanyTo")
  wpsFiles                     WpsFile[]
  accountingAuditLogs          AccountingAuditLog[]
  budgets                      Budget[]
  paymentVouchers              PaymentVoucher[]
  lettersOfCredit              LetterOfCredit[]
  employees                    Employee[]
  hrSalaries                   HRSalary[]
  hrCommissions                HRCommission[]
  hrAttendances                HRAttendance[]
  hrLeaveRequests              HRLeaveRequest[]
  hrPerformances               HRPerformance[]
  orderDeliveries              OrderDelivery[]
  paymentTransactions          PaymentTransaction[]
  stockMovements               StockMovement[]
  setupWizardProgress          SetupWizardProgress?
  companyRuntime               CompanyRuntime?
  aiRequestLogs                AIRequestLog[]
  aiFabricCacheEntries         AIFabricCacheEntry[]
  budgetConfig                 BudgetConfig?
  aiMemoryEntries              AIMemoryEntry[]
  profitSnapshots              ProfitSnapshot[]
  einvoices                    EInvoice[]
  zatcaCertificates            ZatcaCertificate[]
  salesReturns                 SalesReturn[]
  purchaseReturns              PurchaseReturn[]
  bankTransactions             BankTransaction[]
  bankReconciliations          BankReconciliation[]
  depreciationEntries          DepreciationEntry[]
  installmentSchedules         InstallmentSchedule[]

  @@map("companies")
}

model SetupWizardProgress {
  id          Int      @id @default(autoincrement())
  companySlug String   @unique
  currentStep Int      @default(1)
  completed   Boolean  @default(false)
  data        String   @default("{}") // JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companySlug], references: [slug])

  @@map("setup_wizard_progress")
}

// ──────────────────────────────────────────────────────────────────────────────
// Chart of Accounts
// ──────────────────────────────────────────────────────────────────────────────

model Account {
  id          Int      @id @default(autoincrement())
  code        String
  nameAr      String
  nameEn      String?
  type        String // asset, liability, equity, revenue, expense
  parentId    Int?
  companySlug String
  balance     Decimal  @default(0) // Decimal per migration Step 9
  currency    String   @default("KWD")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company  Company   @relation(fields: [companySlug], references: [slug])
  parent   Account?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children Account[] @relation("AccountHierarchy")

  journalEntryLines     JournalEntryLine[]
  openingBalanceEntries OpeningBalanceEntry[]
  bankAccounts          BankAccount[]         @relation("BankAccountGL")
  fixedAssets           FixedAsset[]          @relation("FixedAssetGLAccount")
  fixedAssetsDep        FixedAsset[]          @relation("FixedAssetDepAccount")
  fixedAssetsExpense    FixedAsset[]          @relation("FixedAssetExpenseAccount")
  budgets               Budget[]
  postDatedChecks       PostDatedCheck[]      @relation("PostDatedCheckGLAccount")
  paymentVouchers       PaymentVoucher[]      @relation("PaymentVoucherGLAccount")

  @@unique([code, companySlug])
  @@map("accounts")
}

// ──────────────────────────────────────────────────────────────────────────────
// Clients (Accounts Receivable)
// ──────────────────────────────────────────────────────────────────────────────

model Client {
  id            Int       @id @default(autoincrement())
  name          String
  email         String?
  phone         String?
  clientCompany String? // Client's company name (not our company)
  address       String?
  notes         String?
  companySlug   String
  deletedAt     DateTime?
  deletedBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company         Company          @relation(fields: [companySlug], references: [slug])
  invoices        Invoice[]
  quotations      Quotation[]
  postDatedChecks PostDatedCheck[] @relation("PostDatedCheckClient")
  paymentVouchers PaymentVoucher[] @relation("PaymentVoucherClient")

  @@map("clients")
}

// ──────────────────────────────────────────────────────────────────────────────
// Suppliers (Accounts Payable)
// ──────────────────────────────────────────────────────────────────────────────

model Supplier {
  id          Int       @id @default(autoincrement())
  name        String
  nameEn      String?
  code        String?
  email       String?
  phone       String?
  address     String?
  taxId       String?
  companySlug String
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company         Company          @relation(fields: [companySlug], references: [slug])
  purchaseOrders  PurchaseOrder[]
  postDatedChecks PostDatedCheck[] @relation("PostDatedCheckSupplier")
  paymentVouchers PaymentVoucher[] @relation("PaymentVoucherSupplier")
  lettersOfCredit LetterOfCredit[]

  @@map("suppliers")
}

// ──────────────────────────────────────────────────────────────────────────────
// Product Catalog
// ──────────────────────────────────────────────────────────────────────────────

model ProductCatalog {
  id             Int      @id @default(autoincrement())
  code           String?
  name           String
  aliases        String   @default("[]") // JSON array
  purchasePrice  Decimal? // Decimal per migration Step 6 (nullable)
  sellingPrice   Decimal? // Decimal per migration Step 6 (nullable)
  wholesalePrice Decimal? // Decimal per migration Step 6 (nullable)
  unit           String   @default("piece")
  description    String?
  companySlug    String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company         Company          @relation(fields: [companySlug], references: [slug])
  inventoryItems  InventoryItem[]
  productAliases  ProductAlias[]
  landedCostLines LandedCostLine[]
  stockMovements  StockMovement[]

  @@map("product_catalog")
}

// ──────────────────────────────────────────────────────────────────────────────
// Warehouses
// ──────────────────────────────────────────────────────────────────────────────

model Warehouse {
  id          Int      @id @default(autoincrement())
  companySlug String
  name        String
  code        String
  address     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company        Company         @relation(fields: [companySlug], references: [slug])
  inventoryItems InventoryItem[]
  stockMovements StockMovement[]

  @@unique([companySlug, code])
  @@map("warehouses")
}

// ──────────────────────────────────────────────────────────────────────────────
// Inventory Items
// ──────────────────────────────────────────────────────────────────────────────

model InventoryItem {
  id           Int      @id @default(autoincrement())
  companySlug  String
  warehouseId  Int
  productId    Int
  quantity     String   @default("0") // Stored as string for decimal precision
  reorderLevel String   @default("0")
  reorderQty   String   @default("0")
  batchNumber  String?
  expiryDate   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  warehouse       Warehouse        @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product         ProductCatalog   @relation(fields: [productId], references: [id], onDelete: Cascade)
  company         Company          @relation(fields: [companySlug], references: [slug])
  landedCostLines LandedCostLine[]

  @@unique([warehouseId, productId])
  @@map("inventory_items")
}

// ──────────────────────────────────────────────────────────────────────────────
// Stock Movements
// ──────────────────────────────────────────────────────────────────────────────

model StockMovement {
  id          Int      @id @default(autoincrement())
  companySlug String
  productId   Int?
  warehouseId Int
  qty         String // Stored as string for decimal qty
  sourceType  String // sale, purchase, adjustment, transfer, return
  sourceId    Int?
  note        String?
  unitCost    Decimal? // Decimal per migration Step 36 (nullable)
  totalCost   Decimal? // Decimal per migration Step 36 (nullable)
  createdBy   String   @default("system")
  createdAt   DateTime @default(now())

  company   Company         @relation(fields: [companySlug], references: [slug])
  product   ProductCatalog? @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@map("stock_movements")
}

// ──────────────────────────────────────────────────────────────────────────────
// Invoices (Sales)
// ──────────────────────────────────────────────────────────────────────────────

model Invoice {
  id               Int       @id @default(autoincrement())
  invoiceNumber    String
  companySlug      String
  clientId         Int?
  clientName       String
  clientEmail      String?
  clientPhone      String?
  clientAddress    String?
  issueDate        String
  dueDate          String
  status           String    @default("draft") // draft, sent, overdue, cancelled, paid, partial
  lineItems        String    @default("[]") // JSON array
  subtotal         Decimal   @default(0) // Decimal per migration Step 1
  taxRate          Decimal   @default(0) // Decimal per migration Step 1
  taxAmount        Decimal   @default(0) // Decimal per migration Step 1
  total            Decimal   @default(0) // Decimal per migration Step 1
  shipping         Decimal   @default(0) // Decimal per migration Step 1
  discount         Decimal   @default(0) // Decimal per migration Step 1
  paid             Decimal   @default(0) // Decimal per migration Step 1
  notes            String?
  source           String?
  createdByEmail   String?
  createdByName    String?
  whatsappRawText  String?
  parsedConfidence String?
  journalEntryId   Int?
  eInvoiceStatus   String?
  deliveryMethod   String?
  version          Int       @default(0)
  deletedAt        DateTime?
  deletedBy        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Kuwait Decree 10/2026 compliance fields
  hijriIssueDate        String?
  hijriDueDate          String?
  mociNumber            String?
  invoiceTypeAr         String?
  invoiceTypeEn         String?
  sellerNameAr          String?
  sellerAddressAr       String?
  buyerNameAr           String?
  buyerAddressAr        String?
  lineItemsAr           String?
  notesAr               String?
  currencyDecimalPlaces Int?
  eInvoiceAuthority     String?

  company       Company        @relation(fields: [companySlug], references: [slug])
  client        Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  eInvoice      EInvoice?
  orderDelivery OrderDelivery?

  @@unique([companySlug, invoiceNumber])
  @@map("invoices")
}

model EInvoice {
  id               Int       @id @default(autoincrement())
  invoiceId        Int       @unique
  companySlug      String
  authorityType    String    @default("none")
  submissionStatus String    @default("pending")
  uuid             String?
  xmlHash          String?
  signedXml        String?
  rawXml           String?
  rejectionReason  String?
  submittedAt      DateTime?
  approvedAt       DateTime?
  retryCount       Int       @default(0)
  lastRetryAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  deletedBy        String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companySlug], references: [slug])

  @@map("e_invoices")
}

model ZatcaCertificate {
  id                Int      @id @default(autoincrement())
  companySlug       String
  certificateType   String   // csid | ccd
  serialNumber      String
  expiryDate        DateTime
  status            String   @default("active") // active | expired | revoked | pending
  certificateDataEnc String  // AES-256-GCM encrypted X.509 PEM
  privateKeyDataEnc  String  // AES-256-GCM encrypted ECDSA key PEM
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company Company @relation(fields: [companySlug], references: [slug])

  @@map("zatca_certificates")
}

// ──────────────────────────────────────────────────────────────────────────────
// Purchase Invoices
// ──────────────────────────────────────────────────────────────────────────────

model PurchaseInvoice {
  id               Int       @id @default(autoincrement())
  num              String
  date             String
  supplier         String    @default("")
  companySlug      String
  items            String    @default("[]") // JSON array
  sourceInvoiceIds String    @default("[]") // JSON array
  totalQty         Int       @default(0)
  totalAmount      Decimal   @default(0) // Decimal per migration Step 2
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  deletedBy        String?

  company               Company                @relation(fields: [companySlug], references: [slug])
  landedCostAllocations LandedCostAllocation[]

  @@map("purchase_invoices")
}

// ──────────────────────────────────────────────────────────────────────────────
// Quotations
// ──────────────────────────────────────────────────────────────────────────────

model Quotation {
  id                 Int      @id @default(autoincrement())
  companySlug        String
  quotationNumber    String
  clientId           Int
  date               String
  validUntil         String?
  lineItems          String // JSON array
  subtotal           Decimal  @default(0) // Decimal per migration Step 3
  taxRate            Decimal  @default(0) // Decimal per migration Step 3
  taxAmount          Decimal  @default(0) // Decimal per migration Step 3
  total              Decimal  @default(0) // Decimal per migration Step 3
  notes              String?
  status             String   @default("draft") // draft, accepted, rejected, converted, expired
  convertedInvoiceId Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company Company @relation(fields: [companySlug], references: [slug])
  client  Client  @relation(fields: [clientId], references: [id])

  @@unique([companySlug, quotationNumber])
  @@map("quotations")
}

// ──────────────────────────────────────────────────────────────────────────────
// Purchase Orders
// ──────────────────────────────────────────────────────────────────────────────

model PurchaseOrder {
  id               Int      @id @default(autoincrement())
  companySlug      String
  poNumber         String
  supplierId       Int
  date             String
  expectedDelivery String?
  lineItems        String // JSON array
  subtotal         Decimal  @default(0) // Decimal per migration Step 4
  taxRate          Decimal  @default(0) // Decimal per migration Step 4
  taxAmount        Decimal  @default(0) // Decimal per migration Step 4
  total            Decimal  @default(0) // Decimal per migration Step 4
  notes            String?
  status           String   @default("draft") // draft, issued, received, cancelled
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company  Company  @relation(fields: [companySlug], references: [slug])
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@unique([companySlug, poNumber])
  @@map("purchase_orders")
}

// ──────────────────────────────────────────────────────────────────────────────
// Sales Returns
// ──────────────────────────────────────────────────────────────────────────────

model SalesReturn {
  id          Int      @id @default(autoincrement())
  companySlug String
  invoiceId   Int?
  clientId    Int?
  clientName  String?
  totalAmount Decimal  @default(0) // Decimal per migration Step 7
  status      String   @default("draft")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companySlug], references: [slug])

  @@map("sales_returns")
}

// ──────────────────────────────────────────────────────────────────────────────
// Purchase Returns
// ──────────────────────────────────────────────────────────────────────────────

model PurchaseReturn {
  id                Int      @id @default(autoincrement())
  companySlug       String
  purchaseInvoiceId Int?
  supplierId        Int?
  supplier          String?
  totalAmount       Decimal  @default(0) // Decimal per migration Step 8
  status            String   @default("draft")
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company Company @relation(fields: [companySlug], references: [slug])

  @@map("purchase_returns")
}

// ──────────────────────────────────────────────────────────────────────────────
// Journal Entries (Vouchers in accounting sense)
// ──────────────────────────────────────────────────────────────────────────────

model JournalEntry {
  id           Int       @id @default(autoincrement())
  date         String
  description  String?
  reference    String?
  companySlug  String
  createdBy    String
  status       String    @default("draft") // draft, posted, cancelled
  sourceType   String?
  sourceId     Int?
  currency     String    @default("KWD")
  reversedById Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  deletedBy    String?

  company               Company                   @relation(fields: [companySlug], references: [slug])
  lines                 JournalEntryLine[]
  reversedBy            JournalEntry?             @relation("JournalEntryReverse", fields: [reversedById], references: [id])
  reversals             JournalEntry[]            @relation("JournalEntryReverse")
  interCompanyJEsFrom   InterCompanyTransaction[] @relation("InterCompanyJEFrom")
  interCompanyJEsTo     InterCompanyTransaction[] @relation("InterCompanyJETo")
  postDatedChecks       PostDatedCheck[]
  depreciationEntries   DepreciationEntry[]
  paymentVouchers       PaymentVoucher[]
  fxRevaluations        FxRevaluation[]
  taxFilings            TaxFiling[]
  openingBalanceEntries OpeningBalanceEntry[]

  @@map("journal_entries")
}

model JournalEntryLine {
  id           Int      @id @default(autoincrement())
  entryId      Int
  accountId    Int
  debit        Decimal  @default(0) // Decimal per migration Step 10
  credit       Decimal  @default(0) // Decimal per migration Step 10
  description  String?
  costCenterId Int?
  createdAt    DateTime @default(now())

  entry      JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account    Account      @relation(fields: [accountId], references: [id])
  costCenter CostCenter?  @relation(fields: [costCenterId], references: [id], onDelete: SetNull)

  @@map("journal_entry_lines")
}

// ──────────────────────────────────────────────────────────────────────────────
// Financial Periods (Fiscal Periods)
// ──────────────────────────────────────────────────────────────────────────────

model FiscalPeriod {
  id          Int       @id @default(autoincrement())
  companySlug String
  name        String
  startDate   String
  endDate     String
  fiscalYear  Int
  periodType  String // monthly, quarterly, yearly
  status      String    @default("open") // open, closed, locked
  closedBy    String?
  closedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company Company @relation(fields: [companySlug], references: [slug])

  @@unique([companySlug, name])
  @@map("fiscal_periods")
}

// ──────────────────────────────────────────────────────────────────────────────
// Cost Centers
// ──────────────────────────────────────────────────────────────────────────────

model CostCenter {
  id          Int      @id @default(autoincrement())
  companySlug String
  code        String
  nameAr      String
  nameEn      String?
  parentId    Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company           Company            @relation(fields: [companySlug], references: [slug])
  parent            CostCenter?        @relation("CostCenterHierarchy", fields: [parentId], references: [id])
  children          CostCenter[]       @relation("CostCenterHierarchy")
  budgets           Budget[]
  journalEntryLines JournalEntryLine[]

  @@unique([companySlug, code])
  @@map("cost_centers")
}

// ──────────────────────────────────────────────────────────────────────────────
// Banking Models
// ──────────────────────────────────────────────────────────────────────────────

model BankAccount {
  id            Int      @id @default(autoincrement())
  companySlug   String
  bankName      String
  accountName   String
  accountNumber String
  iban          String?
  branchCode    String?
  currency      String   @default("KWD")
  balance       Decimal  @default(0) // Decimal per migration Step 18
  accountType   String   @default("checking") // checking, savings, cash_vault
  glAccountId   Int?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company             Company              @relation(fields: [companySlug], references: [slug])
  glAccount           Account?             @relation("BankAccountGL", fields: [glAccountId], references: [id])
  bankTransactions    BankTransaction[]
  bankReconciliations BankReconciliation[]
  paymentVouchers     PaymentVoucher[]     @relation("PaymentVoucherBankAccount")
  lettersOfCredit     LetterOfCredit[]

  @@map("bank_accounts")
}

model BankTransaction {
  id              Int      @id @default(autoincrement())
  companySlug     String
  bankAccountId   Int
  date            String
  reference       String?
  description     String?
  amount          Decimal  @default(0) // Decimal per migration Step 19
  transactionType String // deposit, withdrawal, transfer
  isReconciled    Boolean  @default(false)
  reconciledWith  String?
  reconciledId    Int?
  importedFrom    String?
  rawRow          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  company     Company     @relation(fields: [companySlug], references: [slug])

  @@map("bank_transactions")
}

model BankReconciliation {
  id               Int       @id @default(autoincrement())
  companySlug      String
  bankAccountId    Int
  periodStart      String
  periodEnd        String
  statementBalance Decimal   @default(0) // Decimal per migration Step 20
  bookBalance      Decimal   @default(0) // Decimal per migration Step 20
  adjustedBalance  Decimal   @default(0) // Decimal per migration Step 20

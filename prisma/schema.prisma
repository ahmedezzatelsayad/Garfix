// ═══════════════════════════════════════════════════════════════════════════════
// GarfiX ERP — Prisma Schema v2 (P0-1: Full Runtime Model Sync)
// ═══════════════════════════════════════════════════════════════════════════════
//
// NOTE: Financial fields use Decimal instead of Float for production accuracy.
// SQLite doesn't support Decimal, so in dev it falls back to Float-like behavior.
// For PostgreSQL production, Decimal ensures exact precision (no floating-point errors).
//
// This schema aligns model names with db.xxx calls in the runtime code.
// All models referenced in src/ are now defined here.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"  // Change to "postgresql" for production
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════════════
// Core Business Models
// ═══════════════════════════════════════════════════════════════════════════════

// ─── AppUser (replaces User — matches db.appUser) ───

model AppUser {
  uid           String   @id @default(cuid())
  email         String   @unique
  name          String?
  password      String?
  role          String   @default("user")  // user, admin, accountant, viewer
  companyId     String?
  companySlug   String?
  emailVerified Boolean  @default(true)
  tokenVersion  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company? @relation(fields: [companyId], references: [id])

  mFASecrets    MFASecret[]
  sessions      SessionRegistry[]
}


// ─── Company (matches db.company) ───

model Company {
  id                String   @id @default(cuid())
  name              String
  code              String   @unique @default(cuid())
  slug              String   @unique @default("default-slug")
  plan              String   @default("trial")
  subscriptionStatus String  @default("inactive")
  currency          String   @default("USD")
  taxId             String?
  address           String?
  deletedAt         DateTime?  // P0-3: Soft Delete
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  users             AppUser[]
  accounts          Account[]
  clients           Client[]
  suppliers         Supplier[]
  journalEntries    JournalEntry[]
  paymentVouchers   PaymentVoucher[]
  fiscalPeriods     FiscalPeriod[]
  openingBalances   OpeningBalanceEntry[]
  profitDistributions ProfitDistribution[]
  lettersOfCredit   LetterOfCredit[]
  productCatalogs   ProductCatalog[]
  inventoryItems    InventoryItem[]
  warehouses        Warehouse[]
  fixedAssets       FixedAsset[]
  bankAccounts      BankAccount[]
  budgets           Budget[]
  costCenters       CostCenter[]
  employees         Employee[]
  purchaseInvoices  PurchaseInvoice[]
  invoices          Invoice[]
  quotations        Quotation[]
  purchaseOrders    PurchaseOrder[]
}

// ─── Account (Chart of Accounts — matches db.account) ───

model Account {
  id          String   @id @default(cuid())
  code        String
  name        String
  type        String   // asset, liability, equity, revenue, expense
  parentId    String?
  companyId   String
  companySlug String   @default("default")
  balance     Decimal  @default(0)  // Running balance — updated on JE posting
  isActive    Boolean  @default(true)
  version     Int      @default(0)  // P0-8: Optimistic Locking for balance updates
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id])
  parent      Account? @relation("AccountHierarchy", fields: [parentId], references: [id])
  children    Account[] @relation("AccountHierarchy")
  openingBalances OpeningBalanceEntry[]
  journalEntryLines JournalEntryLine[]
  @@unique([code, companyId])
}

// ─── Client (Accounts Receivable — matches db.client) ───

model Client {
  id          String   @id @default(cuid())
  name        String
  code        String   @default(cuid())
  email       String?
  phone       String?
  address     String?
  taxId       String?
  companySlug String   @default("default")
  companyId   String?
  isActive    Boolean  @default(true)
  deletedAt   DateTime?  // P0-3: Soft Delete
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company?  @relation(fields: [companyId], references: [id])
  paymentVouchers PaymentVoucher[]
  invoices     Invoice[]
}

// ─── Supplier (Accounts Payable — matches db.supplier) ───

model Supplier {
  id          String   @id @default(cuid())
  name        String
  code        String
  email       String?
  phone       String?
  address     String?
  taxId       String?
  companyId   String
  companySlug String   @default("default")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id])
  paymentVouchers PaymentVoucher[]
  lettersOfCredit  LetterOfCredit[]
  purchaseInvoices PurchaseInvoice[]
  @@unique([code, companyId])
}

// ─── Product Catalog (matches db.productCatalog) ───

model ProductCatalog {
  id            String   @id @default(cuid())
  name          String
  sku           String   @default("")
  code          String?
  category      String?
  purchasePrice Decimal  @default(0)
  sellingPrice  Decimal  @default(0)
  unit          String   @default("piece")
  description   String?
  companySlug   String   @default("default")
  companyId     String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company?  @relation(fields: [companyId], references: [id])
  inventoryItems InventoryItem[]
  productAliases ProductAlias[]
  productMatchAudits ProductMatchAudit[]
  matchOverrides   MatchOverride[]
}

// ─── Inventory Item (matches db.inventoryItem) ───

model InventoryItem {
  id            String   @id @default(cuid())
  productId     String
  quantity      Decimal  @default(0)
  reorderLevel  Decimal  @default(0)
  warehouseId   String?
  warehouse     String?
  batchNumber   String?
  expiryDate    DateTime?
  companySlug   String   @default("default")
  companyId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  product       ProductCatalog @relation(fields: [productId], references: [id])
  company       Company?  @relation(fields: [companyId], references: [id])
  warehouseRef  Warehouse? @relation(fields: [warehouseId], references: [id])
}

// ─── Warehouse (matches db.warehouse) ───

model Warehouse {
  id          String   @id @default(cuid())
  name        String
  code        String
  companySlug String
  companyId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  inventoryItems InventoryItem[]
  company     Company? @relation(fields: [companyId], references: [id])
}

// ═══════════════════════════════════════════════════════════════════════════════
// Accounting Core Models (P0-2, P0-4, P0-5, P0-8)
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Fiscal Period (matches db.fiscalPeriod — renamed from FinancialPeriod) ───

model FiscalPeriod {
  id          String   @id @default(cuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  status      String   @default("open") // open, closed, locked
  companyId   String
  companySlug String   @default("default")
  closedBy    String?
  closedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id])
  openingBalances OpeningBalanceEntry[]
  @@unique([name, companyId])
}

// ─── Journal Entry (matches db.journalEntry — renamed from Voucher) ───
// P0-2: Posted entries are IMMUTABLE — cannot be deleted/modified
// P0-4: Cannot post to closed/locked periods
// P0-5: Minimum 2 lines, balanced debit/credit, accounts must exist
// P0-8: Version field for optimistic locking

model JournalEntry {
  id            String   @id @default(cuid())
  number        String
  date          DateTime
  description   String?
  reference     String?
  status        String   @default("draft") // draft, posted, cancelled
  entryType     String   @default("general") // general, payment, receipt, transfer
  companyId     String
  companySlug   String   @default("default")
  createdBy     String?
  version       Int      @default(0)  // P0-8: Optimistic Locking
  deletedAt     DateTime?  // P0-3: Soft Delete
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company  @relation(fields: [companyId], references: [id])
  lines         JournalEntryLine[]
  @@unique([number, companyId])
}

// ─── Journal Entry Line (matches db.journalEntryLine — renamed from VoucherLine) ───

model JournalEntryLine {
  id           String   @id @default(cuid())
  accountId    String
  debit        Decimal  @default(0)
  credit       Decimal  @default(0)
  description  String?
  sortOrder    Int      @default(0)
  journalEntryId String
  account      Account  @relation(fields: [accountId], references: [id])
  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
}

// ─── Payment Voucher (matches db.paymentVoucher) ───

model PaymentVoucher {
  id            String   @id @default(cuid())
  number        String
  date          DateTime
  amount        Decimal
  paymentType   String   // receipt, payment
  direction     String   // inbound, outbound
  status        String   @default("draft") // draft, posted, cancelled
  description   String?
  reference     String?
  clientId      String?
  supplierId    String?
  companyId     String
  companySlug   String   @default("default")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  client        Client?  @relation(fields: [clientId], references: [id])
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  company       Company  @relation(fields: [companyId], references: [id])
  installmentSchedules InstallmentSchedule[]
  @@unique([number, companyId])
}

// ─── Installment Schedule (matches db.installmentSchedule) ───

model InstallmentSchedule {
  id              String   @id @default(cuid())
  paymentVoucherId String
  amount          Decimal
  dueDate         DateTime
  status          String   @default("pending") // pending, paid, overdue, cancelled
  paidDate        DateTime?
  paymentRef      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  paymentVoucher  PaymentVoucher @relation(fields: [paymentVoucherId], references: [id], onDelete: Cascade)
}

// ─── Opening Balance Entry (matches db.openingBalanceEntry) ───

model OpeningBalanceEntry {
  id            String   @id @default(cuid())
  accountId     String
  periodId      String
  debit         Decimal  @default(0)
  credit        Decimal  @default(0)
  companyId     String
  companySlug   String   @default("default")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  account       Account  @relation(fields: [accountId], references: [id])
  period        FiscalPeriod @relation(fields: [periodId], references: [id])
  company       Company  @relation(fields: [companyId], references: [id])
  @@unique([accountId, periodId])
}

// ─── Profit Distribution (matches existing) ───

model ProfitDistribution {
  id            String   @id @default(cuid())
  periodId      String?
  totalProfit   Decimal  @default(0)
  retained      Decimal  @default(0)
  distributed   Decimal  @default(0)
  distributionType String @default("proportional")
  status        String   @default("draft") // draft, approved, executed
  notes         String?
  companyId     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company  @relation(fields: [companyId], references: [id])
  entries       ProfitDistributionEntry[]
}

model ProfitDistributionEntry {
  id            String   @id @default(cuid())
  distributionId String
  shareholder   String
  shareRatio    Decimal  @default(0)
  amount        Decimal  @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  distribution  ProfitDistribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)
}

// ─── Letter of Credit (matches db.letterOfCredit) ───

model LetterOfCredit {
  id            String   @id @default(cuid())
  number        String
  type          String   @default("import")
  amount        Decimal
  currency      String   @default("USD")
  status        String   @default("draft")
  issueDate     DateTime?
  expiryDate    DateTime?
  beneficiary   String?
  issuingBank   String?
  description   String?
  reference     String?
  supplierId    String?
  companyId     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  company       Company  @relation(fields: [companyId], references: [id])
  lcDocuments   LetterOfCreditDocument[]
  @@unique([number, companyId])
}

model LetterOfCreditDocument {
  id            String   @id @default(cuid())
  letterOfCreditId String
  documentType  String
  fileName      String
  fileUrl       String?
  uploadedAt    DateTime @default(now())
  letterOfCredit LetterOfCredit @relation(fields: [letterOfCreditId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════════════════════
// Extended Accounting Models
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Bank Account (matches db.bankAccount) ───

model BankAccount {
  id            String   @id @default(cuid())
  name          String
  accountNumber String
  bankName      String
  branch        String?
  iban          String?
  currency      String   @default("USD")
  balance       Decimal  @default(0)
  companyId     String
  companySlug   String   @default("default")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company  @relation(fields: [companyId], references: [id])
  bankTransactions    BankTransaction[]
  bankReconciliations BankReconciliation[]
}

// ─── Bank Transaction (matches db.bankTransaction) ───

model BankTransaction {
  id            String   @id @default(cuid())
  bankAccountId String
  type          String   // deposit, withdrawal, transfer, fee
  amount        Decimal
  reference     String?
  description   String?
  date          DateTime
  reconciled    Boolean  @default(false)
  reconciliationId String?
  companyId     String
  companySlug   String   @default("default")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])
  bankReconciliation BankReconciliation? @relation(fields: [reconciliationId], references: [id])
}

// ─── Bank Reconciliation (matches db.bankReconciliation) ───

model BankReconciliation {
  id            String   @id @default(cuid())
  bankAccountId String
  periodId      String?
  status        String   @default("draft") // draft, in_progress, completed
  startDate     DateTime
  endDate       DateTime
  openingBalance Decimal
  closingBalance Decimal
  companyId     String
  companySlug   String   @default("default")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])
  bankTransactions BankTransaction[]
}

// ─── Fixed Asset (matches db.fixedAsset) ───

model FixedAsset {
  id            String   @id @default(cuid())
  name          String
  code          String
  category      String
  purchaseDate  DateTime
  purchasePrice Decimal
  currentValue  Decimal
  depreciationRate Decimal @default(0)
  accumulatedDepreciation Decimal @default(0)
  usefulLifeYears Int
  status        String   @default("active") // active, disposed, written_off
  companyId     String
  companySlug   String   @default("default")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company  @relation(fields: [companyId], references: [id])
  depreciationEntries DepreciationEntry[]
  @@unique([code, companyId])
}

// ─── Depreciation Entry (matches db.depreciationEntry) ───

model DepreciationEntry {
  id            String   @id @default(cuid())
  assetId       String
  periodId      String?
  amount        Decimal
  date          DateTime
  description   String?
  companyId     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  fixedAsset    FixedAsset @relation(fields: [assetId], references: [id])
}

// ─── Budget (matches db.budget) ───

model Budget {
  id            String   @id @default(cuid())
  name          String
  periodId      String?
  totalAmount   Decimal @default(0)
  status        String   @default("draft") // draft, approved, revised
  companyId     String
  companySlug   String   @default("default")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company  @relation(fields: [companyId], references: [id])
  budgetLines   BudgetLine[]
}

model BudgetLine {
  id            String   @id @default(cuid())
  budgetId      String
  accountId     String
  costCenterId  String?
  plannedAmount Decimal @default(0)
  actualAmount  Decimal @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  budget        Budget     @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  costCenter    CostCenter? @relation(fields: [costCenterId], references: [id])
}

// ─── Cost Center (matches db.costCenter) ───

model CostCenter {
  id            String   @id @default(cuid())
  name          String
  code          String
  description   String?
  companyId     String
  companySlug   String   @default("default")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company  @relation(fields: [companyId], references: [id])
  budgetLines   BudgetLine[]
  @@unique([code, companyId])
}

// ─── FX Revaluation (matches db.fxRevaluation) ───

model FxRevaluation {
  id            String   @id @default(cuid())
  fromCurrency  String
  toCurrency    String
  rate          Decimal
  date          DateTime
  status        String   @default("draft") // draft, posted, cancelled
  companyId     String
  companySlug   String   @default("default")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── Inter-Company Transaction (matches db.interCompanyTransaction) ───

model InterCompanyTransaction {
  id            String   @id @default(cuid())
  type          String   // transfer, invoice, payment
  amount        Decimal
  fromCompanyId String
  toCompanyId   String
  status        String   @default("draft") // draft, posted, settled
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── Landed Cost Allocation (matches db.landedCostAllocation/landedCostLine) ───

model LandedCostAllocation {
  id            String   @id @default(cuid())
  purchaseInvoiceId String?
  description   String?
  totalCost     Decimal @default(0)
  status        String   @default("draft")
  companyId     String
  companySlug   String   @default("default")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lines         LandedCostLine[]
}

model LandedCostLine {
  id                 String   @id @default(cuid())
  allocationId       String
  costType           String   // freight, insurance, customs, handling
  amount             Decimal  @default(0)
  allocationMethod   String   @default("quantity") // quantity, weight, value, manual
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  landedCostAllocation LandedCostAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════════════════════
// HR Models (matches db.hR*, db.employee)
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Employee (matches db.employee) ───

model Employee {
  id            String   @id @default(cuid())
  name          String
  code          String
  department    String?
  position      String?
  hireDate      DateTime?
  salary        Decimal  @default(0)
  companyId     String
  companySlug   String   @default("default")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company  @relation(fields: [companyId], references: [id])
  salaries      HRSalary[]
  commissions   HRCommission[]
  attendances   HRAttendance[]
  leaveRequests HRLeaveRequest[]
  performances  HRPerformance[]
  @@unique([code, companyId])
}

// ─── HR Salary (matches db.hRSalary) ───

model HRSalary {
  id            String   @id @default(cuid())
  employeeId    String
  amount        Decimal
  month         String   // "2026-01"
  status        String   @default("draft") // draft, paid, cancelled
  paidDate      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  employee      Employee @relation(fields: [employeeId], references: [id])
}

// ─── HR Commission (matches db.hRCommission) ───

model HRCommission {
  id            String   @id @default(cuid())
  employeeId    String
  amount        Decimal
  period        String
  status        String   @default("draft")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  employee      Employee @relation(fields: [employeeId], references: [id])
}

// ─── HR Attendance (matches db.hRAttendance) ───

model HRAttendance {
  id            String   @id @default(cuid())
  employeeId    String
  date          DateTime
  checkIn       DateTime?
  checkOut      DateTime?
  status        String   @default("present") // present, absent, late, excused
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  employee      Employee @relation(fields: [employeeId], references: [id])
}

// ─── HR Leave Request (matches db.hRLeaveRequest) ───

model HRLeaveRequest {
  id            String   @id @default(cuid())
  employeeId    String
  type          String   // annual, sick, maternity, emergency
  startDate     DateTime
  endDate       DateTime
  status        String   @default("pending") // pending, approved, rejected
  approvedBy    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  employee      Employee @relation(fields: [employeeId], references: [id])
}

// ─── HR Performance (matches db.hRPerformance) ───

model HRPerformance {
  id            String   @id @default(cuid())
  employeeId    String
  period        String
  rating        Decimal  @default(0)
  goals         String?
  feedback      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  employee      Employee @relation(fields: [employeeId], references: [id])
}

// ═══════════════════════════════════════════════════════════════════════════════
// Invoice & Sales Models
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Invoice (matches db.invoice) ───

model Invoice {
  id            Int      @id @default(autoincrement())
  invoiceNumber String
  clientName    String?
  clientId      String?
  issueDate     DateTime @default(now())
  dueDate       DateTime?
  total         Decimal  @default(0)
  subtotal      Decimal  @default(0)
  taxAmount     Decimal  @default(0)
  status        String   @default("draft") // draft, sent, paid, cancelled
  source        String?
  eInvoiceAuthority String?  // zatca, uae_fta, kuwait_decree_10_2026, etc.
  companySlug   String   @default("default")
  companyId     String?
  version       Int      @default(0)  // P0-8: Optimistic Locking
  deletedAt     DateTime?  // P0-3: Soft Delete
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company?  @relation(fields: [companyId], references: [id])
  client        Client?   @relation(fields: [clientId], references: [id])
  eInvoice      EInvoice?
  paymentTransactions PaymentTransaction[]
}

// ─── Purchase Invoice (matches db.purchaseInvoice) ───

model PurchaseInvoice {
  id            String   @id @default(cuid())
  invoiceNumber String
  supplierId    String?
  issueDate     DateTime @default(now())
  dueDate       DateTime?
  total         Decimal  @default(0)
  status        String   @default("draft") // draft, received, paid, cancelled
  companySlug   String   @default("default")
  companyId     String?
  deletedAt     DateTime?  // P0-3: Soft Delete
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  company       Company?  @relation(fields: [companyId], references: [id])
}


// ─── Quotation (matches db.quotation) ───

model Quotation {
  id            String   @id @default(cuid())
  number        String
  clientId      String?
  issueDate     DateTime @default(now())
  expiryDate    DateTime?
  total         Decimal  @default(0)
  status        String   @default("draft") // draft, sent, accepted, rejected, converted
  companySlug   String   @default("default")
  companyId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company? @relation(fields: [companyId], references: [id])
}

// ─── Purchase Order (matches db.purchaseOrder) ───

model PurchaseOrder {
  id            String   @id @default(cuid())
  number        String
  supplierId    String?
  orderDate     DateTime @default(now())
  expectedDelivery DateTime?
  total         Decimal  @default(0)
  status        String   @default("draft") // draft, confirmed, received, cancelled
  companySlug   String   @default("default")
  companyId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company? @relation(fields: [companyId], references: [id])
}


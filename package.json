{
  "name": "garfix-eos",
  "version": "12.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 2>&1 | tee dev.log",
    "build": "prisma generate && next build && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/",
    "start": "NODE_ENV=production bun .next/standalone/server.js 2>&1 | tee server.log",
    "lint": "eslint .",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "db:status": "prisma migrate status",
    "seed": "bun run scripts/seed.ts",
    "backup": "bun run scripts/backup.ts",
    "archive-audit": "bun run scripts/archiveAuditLogs.ts",
    "test": "bun test",
    "test:lib": "bun test src/lib/__tests__/",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
